// ===============================================
// AI ASSISTANT MODULE
// ===============================================

// --- Enums ---

enum AiPersonality {
  PROFESSIONAL
  FRIENDLY
  CASUAL
  FORMAL
  CUSTOM
}

enum AiToneOfVoice {
  NEUTRAL
  WARM
  DIRECT
  ENTHUSIASTIC
}

enum AiConversationContext {
  DEDICATED
  INLINE
  COMMAND_BAR
  VOICE
}

enum AiConversationStatus {
  ACTIVE
  ARCHIVED
}

enum AiMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL_CALL
  TOOL_RESULT
}

enum AiMessageContentType {
  TEXT
  CHART
  TABLE
  KPI_CARD
  ACTION_CARD
  IMAGE
  ERROR
  LOADING
}

enum AiFavoriteCategory {
  SALES
  STOCK
  FINANCE
  HR
  CRM
  GENERAL
}

enum AiActionStatus {
  PROPOSED
  CONFIRMED
  EXECUTED
  FAILED
  CANCELLED
  UNDONE
}

enum AiInsightType {
  TREND
  ANOMALY
  OPPORTUNITY
  RISK
  PREDICTION
  RECOMMENDATION
  ALERT
  CELEBRATION
}

enum AiInsightPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AiInsightStatus {
  NEW
  VIEWED
  ACTED_ON
  DISMISSED
  EXPIRED
}

// --- Models ---

model AiTenantConfig {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")

  // Identity
  assistantName     String        @default("Atlas") @map("assistant_name") @db.VarChar(64)
  assistantAvatar   String?       @map("assistant_avatar")
  personality       AiPersonality @default(PROFESSIONAL)
  customPersonality String?       @map("custom_personality") @db.Text
  toneOfVoice       AiToneOfVoice @default(NEUTRAL) @map("tone_of_voice")
  language          String        @default("pt-BR") @db.VarChar(8)
  greeting          String?       @db.Text

  // Access Modes
  enableDedicatedChat Boolean @default(true) @map("enable_dedicated_chat")
  enableInlineContext Boolean @default(true) @map("enable_inline_context")
  enableCommandBar    Boolean @default(true) @map("enable_command_bar")
  enableVoice         Boolean @default(false) @map("enable_voice")
  wakeWord            String? @map("wake_word")

  // AI Providers (3-tier)
  tier1Provider      String  @default("GROQ_SMALL") @map("tier1_provider") @db.VarChar(32)
  tier2Provider      String  @default("GROQ") @map("tier2_provider") @db.VarChar(32)
  tier3Provider      String  @default("CLAUDE") @map("tier3_provider") @db.VarChar(32)
  selfHostedEndpoint String? @map("self_hosted_endpoint")
  tier1ApiKey        String? @map("tier1_api_key")
  tier2ApiKey        String? @map("tier2_api_key")
  tier3ApiKey        String? @map("tier3_api_key")

  // Autonomy
  canExecuteActions   Boolean @default(false) @map("can_execute_actions")
  requireConfirmation Boolean @default(true) @map("require_confirmation")
  maxActionsPerMinute Int     @default(5) @map("max_actions_per_minute")

  // Proactive Insights
  enableProactiveInsights Boolean @default(true) @map("enable_proactive_insights")
  insightFrequency        String  @default("DAILY") @map("insight_frequency") @db.VarChar(16)
  enableScheduledReports  Boolean @default(false) @map("enable_scheduled_reports")

  // Module Access
  accessibleModules String[] @map("accessible_modules")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_tenant_configs")
}

model AiConversation {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")

  title             String?               @db.VarChar(256)
  status            AiConversationStatus  @default(ACTIVE)
  context           AiConversationContext @default(DEDICATED)
  contextModule     String?               @map("context_module") @db.VarChar(32)
  contextEntityType String?               @map("context_entity_type") @db.VarChar(64)
  contextEntityId   String?               @map("context_entity_id")
  messageCount      Int                   @default(0) @map("message_count")
  lastMessageAt     DateTime?             @map("last_message_at")
  isPinned          Boolean               @default(false) @map("is_pinned")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AiMessage[]

  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, userId, status])
  @@index([tenantId, updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String @id @default(uuid())
  conversationId String @map("conversation_id")

  role        AiMessageRole
  content     String?              @db.Text
  contentType AiMessageContentType @default(TEXT) @map("content_type")
  renderData  Json?                @map("render_data")
  attachments Json?

  // AI Metadata
  aiTier         Int?     @map("ai_tier")
  aiModel        String?  @map("ai_model") @db.VarChar(64)
  aiTokensInput  Int?     @map("ai_tokens_input")
  aiTokensOutput Int?     @map("ai_tokens_output")
  aiLatencyMs    Int?     @map("ai_latency_ms")
  aiCost         Decimal? @map("ai_cost") @db.Decimal(8, 6)

  // Tool Use
  toolCalls    Json? @map("tool_calls")
  actionsTaken Json? @map("actions_taken")

  // Voice
  audioUrl      String? @map("audio_url")
  transcription String? @db.Text

  // Audit
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

model AiFavoriteQuery {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")

  query      String             @db.VarChar(512)
  shortcut   String?            @db.VarChar(64)
  category   AiFavoriteCategory @default(GENERAL)
  usageCount Int                @default(0) @map("usage_count")
  lastUsedAt DateTime?          @map("last_used_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@map("ai_favorite_queries")
}

model AiActionLog {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")

  conversationId String? @map("conversation_id")
  messageId      String? @map("message_id")

  actionType       String         @map("action_type") @db.VarChar(128)
  targetModule     String         @map("target_module") @db.VarChar(32)
  targetEntityType String         @map("target_entity_type") @db.VarChar(64)
  targetEntityId   String?        @map("target_entity_id")
  input            Json
  output           Json?
  status           AiActionStatus @default(PROPOSED)

  confirmedByUserId String?   @map("confirmed_by_user_id")
  confirmedAt       DateTime? @map("confirmed_at")
  executedAt        DateTime? @map("executed_at")
  error             String?

  // Undo — links to the AuditLog created when this action was executed
  auditLogId String? @map("audit_log_id")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  confirmedBy User?  @relation("AiActionConfirmer", fields: [confirmedByUserId], references: [id])

  @@index([tenantId])
  @@index([tenantId, userId])
  @@index([tenantId, status])
  @@map("ai_action_logs")
}

model AiInsight {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  type     AiInsightType
  priority AiInsightPriority @default(MEDIUM)

  title   String @db.VarChar(256)
  content String @db.Text

  renderData Json? @map("render_data")

  module            String  @db.VarChar(32)
  relatedEntityType String? @map("related_entity_type") @db.VarChar(64)
  relatedEntityId   String? @map("related_entity_id")

  targetUserIds String[] @map("target_user_ids")

  status          AiInsightStatus @default(NEW)
  actionUrl       String?         @map("action_url")
  suggestedAction String?         @map("suggested_action")

  expiresAt   DateTime? @map("expires_at")
  viewedAt    DateTime? @map("viewed_at")
  actedOnAt   DateTime? @map("acted_on_at")
  dismissedAt DateTime? @map("dismissed_at")

  aiModel String? @map("ai_model")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, priority, status])
  @@map("ai_insights")
}

// ===============================================
// PDV (POINT OF SALE) MODULE
// ===============================================

// --- Enums ---

enum PosTerminalMode {
  SALES_ONLY // Só monta carrinho e envia ao caixa (vendedor)
  SALES_WITH_CHECKOUT // Monta carrinho E recebe o pagamento das próprias vendas
  CASHIER // Não monta carrinho — apenas fecha vendas vindas de outros terminais
  TOTEM // Autoatendimento (interface dedicada, sessão por totemCode)
}

enum PosSessionStatus {
  OPEN
  CLOSED
  SUSPENDED
}

enum PosTransactionStatus {
  COMPLETED
  CANCELLED
  SUSPENDED
  PENDING_SYNC
}

enum PosPaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BOLETO
  STORE_CREDIT
  VOUCHER
  PAYMENT_LINK
  NFC
  CHECK
  OTHER
}

enum PosCashMovementType {
  OPENING
  WITHDRAWAL
  SUPPLY
  CLOSING
}

enum PosOfflineStatus {
  PENDING
  SYNCING
  SYNCED
  FAILED
}

enum PosOfflineOperationType {
  TRANSACTION
  CASH_MOVEMENT
  CUSTOMER_CREATE
  SESSION_CLOSE
}

enum PosVisitOutcome {
  SALE
  QUOTE
  NO_SALE
  FOLLOW_UP
}

enum PosPaymentLinkStatus {
  PENDING
  PAID
  EXPIRED
}

// --- Models ---

model PosTerminal {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  // Identificação
  terminalName String          @map("terminal_name") @db.VarChar(128) // "Caixa 01", "Tablet João", "Totem Entrada"
  terminalCode String          @unique @map("terminal_code") @db.VarChar(8) // alfanumérico, único global, usado no pareamento
  totemCode    String?         @unique @map("totem_code") @db.VarChar(8) // só para mode=TOTEM, usado para abrir/fechar a sessão diariamente
  mode         PosTerminalMode

  // Comportamento
  acceptsPendingOrders Boolean @default(false) @map("accepts_pending_orders")
  requiresSession      Boolean @default(true) @map("requires_session")
  allowAnonymous       Boolean @default(false) @map("allow_anonymous") // true para TOTEM (sem usuário humano logado)

  // System user para TOTEM (criado junto com o terminal)
  systemUserId String? @unique @map("system_user_id")

  // Pareamento por código rotativo (TOTP-like, segredo HMAC)
  pairingSecret String? @map("pairing_secret") @db.VarChar(64)

  // Configurações operacionais
  defaultPriceTableId String? @map("default_price_table_id")

  isActive     Boolean   @default(true) @map("is_active")
  lastSyncAt   DateTime? @map("last_sync_at")
  lastOnlineAt DateTime? @map("last_online_at")
  settings     Json?

  // Soft delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  priceTable PriceTable? @relation(fields: [defaultPriceTableId], references: [id])
  systemUser User?       @relation("PosTerminalSystemUser", fields: [systemUserId], references: [id])

  warehouses      PosTerminalWarehouse[]
  devicePairing   PosDevicePairing?
  sessions        PosSession[]
  offlineQueue    PosOfflineQueue[]
  cashierSessions CashierSession[]
  orders          Order[]                @relation("OrderTerminal")

  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, mode])
  @@map("pos_terminals")
}

// Join table — terminal pode operar em N warehouses (vazio = todas as do tenant)
model PosTerminalWarehouse {
  terminalId  String  @map("terminal_id")
  warehouseId String  @map("warehouse_id")
  isDefault   Boolean @default(false) @map("is_default")

  createdAt DateTime @default(now()) @map("created_at")

  terminal  PosTerminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)
  warehouse Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([terminalId, warehouseId])
  @@index([warehouseId])
  @@map("pos_terminal_warehouses")
}

// Pareamento persistente device → terminal (1:1 com terminal — decisão arquitetural)
model PosDevicePairing {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  terminalId      String    @unique @map("terminal_id")
  deviceLabel     String    @map("device_label") @db.VarChar(128)
  deviceTokenHash String    @unique @map("device_token_hash") @db.VarChar(128)
  pairedAt        DateTime  @default(now()) @map("paired_at")
  lastSeenAt      DateTime? @map("last_seen_at")
  pairedByUserId  String    @map("paired_by_user_id")
  revokedAt       DateTime? @map("revoked_at")
  revokedByUserId String?   @map("revoked_by_user_id")
  revokedReason   String?   @map("revoked_reason") @db.VarChar(256)

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terminal PosTerminal @relation(fields: [terminalId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([deviceTokenHash])
  @@map("pos_device_pairings")
}

model PosSession {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  terminalId     String           @map("terminal_id")
  operatorUserId String           @map("operator_user_id")
  status         PosSessionStatus @default(OPEN)

  openedAt DateTime  @default(now()) @map("opened_at")
  closedAt DateTime? @map("closed_at")

  openingBalance  Decimal  @default(0) @map("opening_balance") @db.Decimal(12, 2)
  closingBalance  Decimal? @map("closing_balance") @db.Decimal(12, 2)
  expectedBalance Decimal? @map("expected_balance") @db.Decimal(12, 2)
  difference      Decimal? @db.Decimal(12, 2)

  closingBreakdown Json? @map("closing_breakdown")

  // Sessão fechada retroativamente porque ficou órfã (admin usou close-orphan)
  orphanClosed Boolean @default(false) @map("orphan_closed")

  notes String? @db.Text

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  terminal PosTerminal @relation(fields: [terminalId], references: [id])
  operator User        @relation("PosSessionOperator", fields: [operatorUserId], references: [id])

  transactions PosTransaction[]
  movements    PosCashMovement[]
  orders       Order[]

  @@index([tenantId])
  @@index([terminalId])
  @@index([tenantId, status])
  @@map("pos_sessions")
}

model PosTransaction {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  sessionId         String               @map("session_id")
  orderId           String               @map("order_id")
  transactionNumber Int                  @map("transaction_number")
  status            PosTransactionStatus @default(COMPLETED)

  // Totals
  subtotal      Decimal @db.Decimal(12, 2)
  discountTotal Decimal @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal      Decimal @default(0) @map("tax_total") @db.Decimal(12, 2)
  grandTotal    Decimal @map("grand_total") @db.Decimal(12, 2)
  changeAmount  Decimal @default(0) @map("change_amount") @db.Decimal(12, 2)

  // Customer
  customerId       String? @map("customer_id")
  customerName     String? @map("customer_name") @db.VarChar(128)
  customerDocument String? @map("customer_document") @db.VarChar(20)

  // Supervisor override
  overrideByUserId String? @map("override_by_user_id")
  overrideReason   String? @map("override_reason") @db.VarChar(256)

  // Sync
  syncedAt DateTime? @map("synced_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session  PosSession @relation(fields: [sessionId], references: [id])
  order    Order      @relation(fields: [orderId], references: [id])
  customer Customer?  @relation(fields: [customerId], references: [id])

  payments PosTransactionPayment[]

  @@unique([sessionId, transactionNumber])
  @@index([tenantId])
  @@index([sessionId])
  @@index([orderId])
  @@index([tenantId, syncedAt])
  @@map("pos_transactions")
}

model PosTransactionPayment {
