  PROCESSING
  CALCULATED
  APPROVED
  PAID
  CANCELLED
}

enum PayrollItemType {
  BASE_SALARY
  BONUS
  COMMISSION
  OVERTIME
  OVERTIME_100
  NIGHT_SHIFT
  DSR
  HAZARD_PAY
  DANGER_PAY
  VACATION_PAY
  THIRTEENTH_SALARY
  HOLIDAY
  INSS
  IRRF
  FGTS
  HEALTH_INSURANCE
  DENTAL_PLAN
  TRANSPORT_VOUCHER
  MEAL_VOUCHER
