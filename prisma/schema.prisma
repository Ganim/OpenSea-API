model StorageFolder {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  parentId String? @map("parent_id")

  name  String  @db.VarChar(256)
  slug  String  @db.VarChar(256)
  path  String  @db.VarChar(1024)
  icon  String? @db.VarChar(64)
  color String? @db.VarChar(7)

  isSystem       Boolean @default(false) @map("is_system")
  isFilter       Boolean @default(false) @map("is_filter")
  filterFileType String? @map("filter_file_type") @db.VarChar(64)

  module     String? @db.VarChar(32)
  entityType String? @map("entity_type") @db.VarChar(64)
  entityId   String? @map("entity_id")
  depth      Int     @default(0)
  createdBy  String? @map("created_by")

  // Security
  isProtected    Boolean @default(false) @map("is_protected")
  protectionHash String? @map("protection_hash") @db.VarChar(256)
  isHidden       Boolean @default(false) @map("is_hidden")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  parent        StorageFolder?     @relation("FolderHierarchy", fields: [parentId], references: [id])
  children      StorageFolder[]    @relation("FolderHierarchy")
  files         StorageFile[]
  accessRules   FolderAccessRule[]
  createdByUser User?              @relation("StorageFolderCreator", fields: [createdBy], references: [id])
  boards        Board[]

  @@unique([tenantId, path, deletedAt], name: "storage_folders_path_tenant_unique")
  @@index([tenantId])
  @@index([parentId])
  @@index([path])
  @@index([module])
  @@index([entityType, entityId])
  @@index([createdBy])
  @@index([tenantId, deletedAt])
  @@index([tenantId, parentId, deletedAt])
  @@map("storage_folders")
}

model StorageFile {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  folderId String? @map("folder_id")

  name         String  @db.VarChar(256)
  originalName String  @map("original_name") @db.VarChar(256)
  fileKey      String  @map("file_key") @db.VarChar(512)
  path         String  @db.VarChar(1280)
  size         Int
  mimeType     String  @map("mime_type") @db.VarChar(128)
  fileType     String  @map("file_type") @db.VarChar(64)
  thumbnailKey String? @map("thumbnail_key") @db.VarChar(512)

  status         StorageFileStatus @default(ACTIVE)
  currentVersion Int               @default(1) @map("current_version")

  entityType String?   @map("entity_type") @db.VarChar(64)
  entityId   String?   @map("entity_id")
  expiresAt  DateTime? @map("expires_at")
  uploadedBy String    @map("uploaded_by")

  // Security
  isEncrypted    Boolean @default(false) @map("is_encrypted")
  isProtected    Boolean @default(false) @map("is_protected")
  protectionHash String? @map("protection_hash") @db.VarChar(256)
  isHidden       Boolean @default(false) @map("is_hidden")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  folder          StorageFolder?       @relation(fields: [folderId], references: [id])
  versions        StorageFileVersion[]
  shareLinks      StorageShareLink[]
  cardAttachments CardAttachment[]

  // Catalogs & Content AI Relations
  catalogCoverImages      Catalog[]          @relation("CatalogCoverImage")
  catalogExportFiles      CatalogExport[]    @relation("CatalogExportFile")
  tenantBrandLogos        TenantBrand[]      @relation("TenantBrandLogo")
  tenantBrandLogoIcons    TenantBrand[]      @relation("TenantBrandLogoIcon")
  contentTemplatePreviews ContentTemplate[]  @relation("ContentTemplatePreview")
  generatedContentFiles   GeneratedContent[] @relation("GeneratedContentFile")
  generatedContentThumbs  GeneratedContent[] @relation("GeneratedContentThumbnail")
  mockupClientLogos       ProductMockup[]    @relation("MockupClientLogo")
  mockupResultFiles       ProductMockup[]    @relation("MockupResultFile")

  // Digital Signature Relations
  certificatePfxFiles   DigitalCertificate[]      @relation("CertificatePfxFile")
  envelopeDocumentFiles SignatureEnvelope[]       @relation("EnvelopeDocumentFile")
  envelopeSignedFiles   SignatureEnvelope[]       @relation("EnvelopeSignedFile")
  signerSignatureImages SignatureEnvelopeSigner[] @relation("SignerSignatureImage")

  // Analytics Relations
  analyticsReportLastFiles       AnalyticsReport[]           @relation("AnalyticsReportLastFile")
  analyticsReportGenerationFiles AnalyticsReportGeneration[] @relation("AnalyticsReportGenerationFile")

  // POS Relations
  posVisitSignatures PosVisitLog[]

  // Licitacoes Relations
  bidEditalFiles   Bid[]         @relation("BidEditalFile")
  bidEtpFiles      Bid[]         @relation("BidEtpFile")
  bidTrFiles       Bid[]         @relation("BidTrFile")
  bidProposalFiles BidProposal[] @relation("BidProposalFile")
  bidDocumentFiles BidDocument[] @relation("BidDocumentFile")
  bidContractFiles BidContract[] @relation("BidContractFile")

  @@unique([tenantId, path, deletedAt], name: "storage_files_path_tenant_unique")
  @@index([tenantId])
  @@index([folderId])
  @@index([fileType])
  @@index([entityType, entityId])
  @@index([uploadedBy])
  @@index([tenantId, deletedAt])
  @@index([tenantId, folderId, deletedAt])
  @@map("storage_files")
}

model StorageFileVersion {
  id     String @id @default(uuid())
  fileId String @map("file_id")

  version    Int
  fileKey    String  @map("file_key") @db.VarChar(512)
  size       Int
  mimeType   String  @map("mime_type") @db.VarChar(128)
  changeNote String? @map("change_note") @db.VarChar(512)
