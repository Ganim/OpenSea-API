  ownerCanDelete Boolean @default(true) @map("owner_can_delete")
  ownerCanShare  Boolean @default(true) @map("owner_can_share")
  ownerCanManage Boolean @default(true) @map("owner_can_manage")

  adminCanRead   Boolean @default(true) @map("admin_can_read")
  adminCanCreate Boolean @default(true) @map("admin_can_create")
  adminCanEdit   Boolean @default(true) @map("admin_can_edit")
  adminCanDelete Boolean @default(false) @map("admin_can_delete")
  adminCanShare  Boolean @default(false) @map("admin_can_share")
