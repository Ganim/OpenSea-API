model AdmissionInvite {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  token             String    @unique @default(uuid())
  email             String?   @db.VarChar(255)
  phone             String?   @db.VarChar(30)
  fullName          String    @map("full_name") @db.VarChar(255)
  positionId        String?   @map("position_id")
  departmentId      String?   @map("department_id")
  companyId         String?   @map("company_id")
  expectedStartDate DateTime? @map("expected_start_date")
  salary            Decimal?  @db.Decimal(12, 2)
  contractType      String?   @default("CLT") @map("contract_type") @db.VarChar(30)
  workRegime        String?   @default("FULL_TIME") @map("work_regime") @db.VarChar(30)
  status            String    @default("PENDING") @db.VarChar(20) // PENDING, IN_PROGRESS, COMPLETED, EXPIRED, CANCELLED
  candidateData     Json?     @map("candidate_data")
  expiresAt         DateTime? @map("expires_at")
  completedAt       DateTime? @map("completed_at")
  employeeId        String?   @map("employee_id")
  createdBy         String?   @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  position   Position?           @relation(fields: [positionId], references: [id])
  department Department?         @relation(fields: [departmentId], references: [id])
  documents  AdmissionDocument[]
  signatures DigitalSignature[]

  @@index([tenantId, status])
  @@index([token])
  @@map("admission_invites")
}

model AdmissionDocument {
  id                String    @id @default(uuid())
  admissionInviteId String    @map("admission_invite_id")
  tenantId          String    @map("tenant_id")
  type              String    @db.VarChar(30) // RG, CPF, CTPS, PROOF_ADDRESS, PHOTO, BIRTH_CERT, MARRIAGE_CERT, OTHER
  fileName          String    @map("file_name") @db.VarChar(500)
  fileUrl           String    @map("file_url") @db.VarChar(1000)
  status            String    @default("PENDING") @db.VarChar(20) // PENDING, UPLOADED, VALIDATED, REJECTED
