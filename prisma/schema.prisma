  items             CatalogItem[]
  exports           CatalogExport[]
  generatedContents GeneratedContent[]
  emailCampaigns    EmailCampaign[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, assignedToUserId])
  @@map("catalogs")
}

model CatalogItem {
