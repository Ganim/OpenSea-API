  // Relations
  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract BidContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([tenantId, empenhoNumber])
  @@index([tenantId])
  @@index([contractId])
  @@map("bid_empenhos")
