  @@map("esocial_configs")
}

model EsocialCertificate {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")

  // Encrypted PFX data
  encryptedPfx  Bytes  @map("encrypted_pfx")
  encryptionIv  String @map("encryption_iv") @db.VarChar(64)
  encryptionTag String @map("encryption_tag") @db.VarChar(64)

  // Encrypted PFX passphrase (AES-256-GCM, same key as PFX).
  // Required so SOAP transmission can actually sign with the A1 cert — without
  // this the PFX can only be used if it was uploaded passphrase-less (which
  // ICP-Brasil certs never are).
  encryptedPassphrase Bytes?  @map("encrypted_passphrase")
  passphraseIv        String? @map("passphrase_iv") @db.VarChar(64)
  passphraseTag       String? @map("passphrase_tag") @db.VarChar(64)

  // Certificate metadata (extracted on upload)
  serialNumber String   @map("serial_number") @db.VarChar(128)
  issuer       String   @db.VarChar(512)
  subject      String   @db.VarChar(512)
  validFrom    DateTime @map("valid_from")
  validUntil   DateTime @map("valid_until")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("esocial_certificates")
}

model EsocialEvent {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  // Event identification
  eventType   String             @map("event_type") @db.VarChar(16) // S-1000, S-1200, S-2200, etc.
  description String             @db.VarChar(512)
  status      EsocialEventStatus @default(DRAFT)

  // Reference (employee, company, etc.)
  referenceId   String? @map("reference_id")
  referenceName String? @map("reference_name") @db.VarChar(256)
  referenceType String? @map("reference_type") @db.VarChar(64) // employee, company, etc.

  // Period
  periodStart DateTime? @map("period_start")
  periodEnd   DateTime? @map("period_end")
  deadline    DateTime?

  // XML content
  xmlContent String? @map("xml_content") @db.Text
  signedXml  String? @map("signed_xml") @db.Text

  // Transmission info
  batchId          String? @map("batch_id")
  receipt          String? @db.VarChar(128)
  rejectionCode    String? @map("rejection_code") @db.VarChar(32)
  rejectionMessage String? @map("rejection_message") @db.Text

  // Retry info
  retryCount  Int       @default(0) @map("retry_count")
  nextRetryAt DateTime? @map("next_retry_at")

  // Rectification
  rectifiedEventId String? @map("rectified_event_id")

  // Audit
  createdBy  String?   @map("created_by")
  reviewedBy String?   @map("reviewed_by")
  reviewedAt DateTime? @map("reviewed_at")
  approvedBy String?   @map("approved_by")
  approvedAt DateTime? @map("approved_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant                      @relation(fields: [tenantId], references: [id])
  batch         EsocialBatch?               @relation(fields: [batchId], references: [id])
  statusHistory EsocialEventStatusHistory[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, eventType])
  @@index([batchId])
  @@map("esocial_events")
}

model EsocialBatch {
  id       String @id @default(uuid())
