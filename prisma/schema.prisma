  pendingIssues Json      @default("[]") @map("pending_issues")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, cpfHash, deletedAt], name: "organization_stakeholders_org_cpf_unique_active")
  @@index([organizationId])
  @@index([cpfHash])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("organization_stakeholders")
}

model Supplier {
  id             String  @id @default(uuid())
  sequentialCode Int     @default(autoincrement()) @map("sequential_code")
  name           String  @db.VarChar(128)
  cnpj           String? @db.VarChar(256)
  taxId          String? @map("tax_id") @db.VarChar(32) // Inscrição Estadual
  contact        String? @db.VarChar(256)

  // Contato
  email   String? @db.VarChar(512)
  phone   String? @db.VarChar(256)
  website String? @db.VarChar(512)

  // Endereço
  address String? @db.VarChar(512)
  city    String? @db.VarChar(128)
  state   String? @db.VarChar(2) // UF
  zipCode String? @map("zip_code") @db.VarChar(10)

  // Blind index hashes
  cnpjHash  String? @map("cnpj_hash") @db.VarChar(64)
  emailHash String? @map("email_hash") @db.VarChar(64)

  country String? @db.VarChar(64)

  // Gestão Comercial
  paymentTerms String?  @map("payment_terms") @db.VarChar(256)
  rating       Decimal? @db.Decimal(3, 2) // 0.00 a 5.00
