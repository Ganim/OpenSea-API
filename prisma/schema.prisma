model EmployeeWarning {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  employeeId String @map("employee_id")
  issuedBy   String @map("issued_by") // employee ID of the manager who issued

  type     String @db.VarChar(32) // VERBAL, WRITTEN, SUSPENSION, TERMINATION_WARNING
  severity String @db.VarChar(16) // LOW, MEDIUM, HIGH, CRITICAL
  reason   String @db.Text

  description  String?  @db.Text
  incidentDate DateTime @map("incident_date")
  witnessName  String?  @map("witness_name") @db.VarChar(256)

  employeeAcknowledged Boolean   @default(false) @map("employee_acknowledged")
  acknowledgedAt       DateTime? @map("acknowledged_at")

  suspensionDays Int?    @map("suspension_days") // only for SUSPENSION type
  attachmentUrl  String? @map("attachment_url") @db.VarChar(512)

  status       String    @default("ACTIVE") @db.VarChar(16) // ACTIVE, REVOKED, EXPIRED
  revokedAt    DateTime? @map("revoked_at")
  revokeReason String?   @map("revoke_reason") @db.Text

  // Soft Delete — P0 compliance: CLT art. 474 and MTE guidance require
  // disciplinary history to remain retrievable even after a "delete" for
  // ongoing labor-court investigation. deletedBy is the user id (not
  // employee id) that triggered the soft-delete, captured for audit.
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  employee Employee @relation(fields: [employeeId], references: [id])
  issuer   Employee @relation("WarningIssuer", fields: [issuedBy], references: [id])
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, deletedAt])
  @@index([employeeId])
  @@index([issuedBy])
  @@index([type])
  @@index([status])
  @@map("employee_warnings")
}

model EmployeeDependant {
