  createdAt DateTime  @default(now()) @map("created_at")
  syncedAt  DateTime? @map("synced_at")

  // Relations
  terminal PosTerminal @relation(fields: [terminalId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([terminalId, status])
