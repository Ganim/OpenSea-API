  @@unique([code, tenantId, deletedAt], name: "finance_entries_code_tenant_unique_active")
  @@index([tenantId])
  @@index([type])
  @@index([categoryId])
  @@index([costCenterId])
  @@index([bankAccountId])
  @@index([status])
  @@index([dueDate])
  @@index([paymentDate])
  @@index([recurrenceType])
  @@index([parentEntryId])
  @@index([createdBy])
  @@index([deletedAt])
  @@index([contractId])
  @@index([tenantId, type, status])
  @@index([tenantId, dueDate, status])
  @@map("finance_entries")
}

