  PENDING
  TRANSMITTING
  TRANSMITTED
  PARTIALLY_ACCEPTED
  ACCEPTED
  REJECTED
  ERROR
}

model EsocialConfig {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")

  environment      EsocialEnvironment @default(HOMOLOGACAO)
