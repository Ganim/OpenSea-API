  @@unique([code, tenantId], name: "manufacturers_code_tenant_unique")
  @@index([isActive])
  @@index([rating])
  @@index([sequentialCode])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("manufacturers")
