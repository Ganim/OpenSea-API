  employerContribution Decimal?  @default(0) @map("employer_contribution") @db.Decimal(10, 2)
  dependantIds         Json?     @map("dependant_ids") // string[] of dependant IDs covered
  metadata             Json? // Extra data per enrollment

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  employee    Employee    @relation(fields: [employeeId], references: [id])
  benefitPlan BenefitPlan @relation(fields: [benefitPlanId], references: [id])

  @@index([tenantId, employeeId])
  @@index([tenantId, benefitPlanId])
  @@index([tenantId, status])
  @@map("benefit_enrollments")
}

// ===============================================
// TRAINING MODULE
// ===============================================

model TrainingProgram {
  id                    String    @id @default(cuid())
  tenantId              String    @map("tenant_id")
  name                  String    @db.VarChar(128)
  description           String?   @db.VarChar(1000)
  category              String    @db.VarChar(32) // ONBOARDING, SAFETY, TECHNICAL, COMPLIANCE, LEADERSHIP, SOFT_SKILLS
  format                String    @db.VarChar(16) // PRESENCIAL, ONLINE, HIBRIDO
  durationHours         Int       @map("duration_hours")
  instructor            String?   @db.VarChar(128)
  maxParticipants       Int?      @map("max_participants")
  isActive              Boolean   @default(true) @map("is_active")
  isMandatory           Boolean   @default(false) @map("is_mandatory")
  // When true, completing this program automatically enqueues an S-2240
  // (Condições Ambientais do Trabalho) draft event for manager review.
  isMandatoryForESocial Boolean   @default(false) @map("is_mandatory_for_esocial")
  validityMonths        Int?      @map("validity_months")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  deletedAt             DateTime? @map("deleted_at")

  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  enrollments TrainingEnrollment[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, isActive])
  @@index([tenantId, category])
  @@map("training_programs")
}

model TrainingEnrollment {
  id                String    @id @default(cuid())
  tenantId          String    @map("tenant_id")
  trainingProgramId String    @map("training_program_id")
  employeeId        String    @map("employee_id")
  status            String    @default("ENROLLED") @db.VarChar(16) // ENROLLED, IN_PROGRESS, COMPLETED, CANCELLED, FAILED
  enrolledAt        DateTime  @default(now()) @map("enrolled_at")
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  // Certificate expiration — computed on complete() from the program's
  // validityMonths (defaulting to 24 when the program leaves it unset).
  expirationDate    DateTime? @map("expiration_date")
  score             Float?
  certificateUrl    String?   @map("certificate_url") @db.VarChar(500)
  notes             String?   @db.VarChar(1000)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  trainingProgram TrainingProgram @relation(fields: [trainingProgramId], references: [id])
  employee        Employee        @relation(fields: [employeeId], references: [id])

  @@unique([trainingProgramId, employeeId])
  @@index([tenantId])
  @@index([tenantId, employeeId])
  @@index([tenantId, trainingProgramId])
  @@index([tenantId, status])
  @@index([tenantId, expirationDate])
  @@map("training_enrollments")
}

// ===============================================
// PERFORMANCE REVIEWS MODULE
// ===============================================

model ReviewCycle {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  name        String    @db.VarChar(128)
  description String?   @db.VarChar(1000)
  type        String    @db.VarChar(32) // ANNUAL, SEMI_ANNUAL, QUARTERLY, PROBATION, CUSTOM
  startDate   DateTime  @map("start_date")
  endDate     DateTime  @map("end_date")
  status      String    @default("DRAFT") @db.VarChar(16) // DRAFT, OPEN, IN_REVIEW, CALIBRATION, CLOSED
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  tenant  Tenant              @relation(fields: [tenantId], references: [id])
  reviews PerformanceReview[]

  @@index([tenantId, deletedAt])
  @@index([tenantId, status])
  @@index([tenantId, isActive])
  @@map("review_cycles")
}

model PerformanceReview {
  id                   String    @id @default(cuid())
  tenantId             String    @map("tenant_id")
  reviewCycleId        String    @map("review_cycle_id")
  employeeId           String    @map("employee_id")
  reviewerId           String    @map("reviewer_id")
  status               String    @default("PENDING") @db.VarChar(32) // PENDING, SELF_ASSESSMENT, MANAGER_REVIEW, COMPLETED
  selfScore            Float?    @map("self_score")
  managerScore         Float?    @map("manager_score")
  finalScore           Float?    @map("final_score")
  selfComments         String?   @map("self_comments") @db.VarChar(2000)
  managerComments      String?   @map("manager_comments") @db.VarChar(2000)
  strengths            String?   @db.VarChar(2000)
  improvements         String?   @db.VarChar(2000)
  goals                String?   @db.VarChar(2000)
  employeeAcknowledged Boolean   @default(false) @map("employee_acknowledged")
  acknowledgedAt       DateTime? @map("acknowledged_at")
  completedAt          DateTime? @map("completed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  reviewCycle  ReviewCycle        @relation(fields: [reviewCycleId], references: [id])
  employee     Employee           @relation("ReviewEmployee", fields: [employeeId], references: [id])
  reviewer     Employee           @relation("ReviewReviewer", fields: [reviewerId], references: [id])
  competencies ReviewCompetency[]

  @@unique([reviewCycleId, employeeId])
  @@index([tenantId])
  @@index([tenantId, reviewCycleId])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("performance_reviews")
}

// ===============================================
// SURVEYS (Pesquisas de Clima)
// ===============================================

model Survey {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  title       String   @db.VarChar(256)
  description String?  @db.VarChar(2000)
  type        String   @db.VarChar(32) // ENGAGEMENT, SATISFACTION, PULSE, EXIT, CUSTOM
  status      String   @default("DRAFT") @db.VarChar(16) // DRAFT, ACTIVE, CLOSED, ARCHIVED
  isAnonymous Boolean  @default(false) @map("is_anonymous")
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  creator   Employee         @relation("SurveyCreator", fields: [createdBy], references: [id])
  questions SurveyQuestion[]
  responses SurveyResponse[]

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, createdBy])
  @@map("surveys")
}

model SurveyQuestion {
  id         String  @id @default(cuid())
  tenantId   String  @map("tenant_id")
  surveyId   String  @map("survey_id")
  text       String  @db.VarChar(1000)
  type       String  @db.VarChar(32) // RATING_1_5, RATING_1_10, YES_NO, TEXT, MULTIPLE_CHOICE, NPS
  options    Json? // For MULTIPLE_CHOICE: ["Option A", "Option B", ...]
  order      Int
  isRequired Boolean @default(true) @map("is_required")
  category   String  @db.VarChar(32) // ENGAGEMENT, LEADERSHIP, CULTURE, WORK_LIFE, GROWTH, COMPENSATION, CUSTOM

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant         @relation(fields: [tenantId], references: [id])
  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@index([tenantId, surveyId])
  @@index([surveyId, order])
  @@map("survey_questions")
}

model SurveyResponse {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  surveyId    String   @map("survey_id")
  employeeId  String?  @map("employee_id") // Nullable if anonymous — MUST be NULL when survey.isAnonymous=true
  submittedAt DateTime @default(now()) @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")

  // Anonymity-preserving dedupe hash.
  // When the survey is anonymous, we cannot persist employeeId (psychological
  // safety guarantee) but we still need to reject duplicate submissions from
  // the same respondent. We store sha256(tenantId || surveyId || employeeId ||
  // ANON_HASH_SECRET) here so the server can check "already submitted?" without
  // being able to reverse-engineer the employee identity. This field is NEVER
  // returned through any API — internal dedupe only.
  respondentHash String? @map("respondent_hash") @db.VarChar(64)

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  survey   Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  employee Employee?      @relation("SurveyResponseEmployee", fields: [employeeId], references: [id])
  answers  SurveyAnswer[]

  @@unique([surveyId, respondentHash])
  @@index([tenantId, surveyId])
  @@index([tenantId, employeeId])
  @@map("survey_responses")
}

model SurveyAnswer {
  id               String  @id @default(cuid())
  tenantId         String  @map("tenant_id")
  surveyResponseId String  @map("survey_response_id")
  questionId       String  @map("question_id")
  ratingValue      Int?    @map("rating_value")
  textValue        String? @map("text_value") @db.VarChar(2000)
  selectedOptions  Json?   @map("selected_options") // For MULTIPLE_CHOICE: ["Option A"]

  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant         @relation(fields: [tenantId], references: [id])
  response SurveyResponse @relation(fields: [surveyResponseId], references: [id], onDelete: Cascade)
  question SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([surveyResponseId, questionId])
  @@index([tenantId, surveyResponseId])
  @@index([tenantId, questionId])
  @@map("survey_answers")
}

// ===============================================
// OKRs (Objectives and Key Results)
// ===============================================

model Objective {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  title       String   @db.VarChar(256)
  description String?  @db.VarChar(2000)
  ownerId     String   @map("owner_id")
  parentId    String?  @map("parent_id")
  level       String   @db.VarChar(16) // COMPANY, DEPARTMENT, TEAM, INDIVIDUAL
  status      String   @default("DRAFT") @db.VarChar(16) // DRAFT, ACTIVE, COMPLETED, CANCELLED
  period      String   @db.VarChar(16) // e.g., Q1_2026, Q2_2026
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  progress    Float    @default(0) // 0-100, computed from key results
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  owner      Employee    @relation("ObjectiveOwner", fields: [ownerId], references: [id])
  parent     Objective?  @relation("ObjectiveParent", fields: [parentId], references: [id])
  children   Objective[] @relation("ObjectiveParent")
  keyResults KeyResult[]

  @@index([tenantId, status])
  @@index([tenantId, ownerId])
  @@index([tenantId, level])
  @@index([tenantId, period])
  @@index([tenantId, parentId])
  @@map("objectives")
}

model KeyResult {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  objectiveId  String   @map("objective_id")
  title        String   @db.VarChar(256)
  description  String?  @db.VarChar(2000)
  type         String   @db.VarChar(16) // NUMERIC, PERCENTAGE, CURRENCY, BINARY
  startValue   Float    @default(0) @map("start_value")
  targetValue  Float    @map("target_value")
  currentValue Float    @default(0) @map("current_value")
  unit         String?  @db.VarChar(32)
  status       String   @default("ON_TRACK") @db.VarChar(16) // ON_TRACK, AT_RISK, BEHIND, COMPLETED
  weight       Float    @default(1) // For weighted progress calculation
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant       @relation(fields: [tenantId], references: [id])
  objective Objective    @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  checkIns  OKRCheckIn[]

  @@index([tenantId, objectiveId])
  @@index([tenantId, status])
  @@map("key_results")
}

model OKRCheckIn {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  keyResultId   String   @map("key_result_id")
  employeeId    String   @map("employee_id")
  previousValue Float    @map("previous_value")
  newValue      Float    @map("new_value")
  note          String?  @db.VarChar(2000)
  confidence    String   @db.VarChar(8) // LOW, MEDIUM, HIGH
  createdAt     DateTime @default(now()) @map("created_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  keyResult KeyResult @relation(fields: [keyResultId], references: [id], onDelete: Cascade)
  employee  Employee  @relation("OKRCheckInEmployee", fields: [employeeId], references: [id])

  @@index([tenantId, keyResultId])
  @@index([tenantId, employeeId])
  @@map("okr_check_ins")
}

model FlexBenefitAllocation {
  id          String    @id @default(cuid())
  tenantId    String    @map("tenant_id")
  employeeId  String    @map("employee_id")
  month       Int
  year        Int
  totalBudget Decimal   @map("total_budget") @db.Decimal(10, 2)
  allocations Json // { category: amount }
  status      String    @default("DRAFT") @db.VarChar(16) // DRAFT, CONFIRMED, LOCKED
  confirmedAt DateTime? @map("confirmed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, month, year])
  @@index([tenantId, month, year])
  @@map("flex_benefit_allocations")
}

// ===============================================
// COMPANY MODULE
// ===============================================

enum CompanyAddressType {
  FISCAL
  DELIVERY
  BILLING
  OTHER
}

enum CompanyCnaeStatus {
  ACTIVE
  INACTIVE
}

enum NfeEnvironment {
  HOMOLOGATION
  PRODUCTION
}

enum DigitalCertificateType {
  NONE
  A1
  A3
}

enum CompanyStakeholderRole {
  SOCIO
  ADMINISTRADOR
  PROCURADOR
  REPRESENTANTE_LEGAL
  GERENTE
  DIRETOR
  OUTRO
}

enum CompanyStakeholderStatus {
  ACTIVE
  INACTIVE
}

enum CompanyStakeholderSource {
  CNPJ_API
  MANUAL
}

model Company {
  id String @id @default(uuid())

  // Multi-Tenant
  tenantId String @map("tenant_id")

  // Dados obrigatórios
  legalName String @map("legal_name") @db.VarChar(256)
  cnpj      String @db.VarChar(256)

  // Dados opcionais principais
  tradeName             String?           @map("trade_name") @db.VarChar(256)
  stateRegistration     String?           @map("state_registration") @db.VarChar(128)
  municipalRegistration String?           @map("municipal_registration") @db.VarChar(128)
  legalNature           String?           @map("legal_nature") @db.VarChar(256)
  taxRegime             TaxRegimeEnum?    @map("tax_regime")
  taxRegimeDetail       String?           @map("tax_regime_detail") @db.VarChar(256)
  activityStartDate     DateTime?         @map("activity_start_date")
  status                CompanyStatusEnum @default(ACTIVE)
  email                 String?           @db.VarChar(256)
  phoneMain             String?           @map("phone_main") @db.VarChar(256)
  phoneAlt              String?           @map("phone_alt") @db.VarChar(256)
  logoUrl               String?           @map("logo_url") @db.VarChar(512)

  // Blind index hash
  cnpjHash String? @map("cnpj_hash") @db.VarChar(64)

  // Metadados e pendências
  metadata      Json     @default("{}")
  pendingIssues String[] @default([])

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant                 @relation(fields: [tenantId], references: [id])
  employees      Employee[]
  departments    Department[]
  addresses      CompanyAddress[]
  cnaes          CompanyCnae[]
  fiscalSettings CompanyFiscalSettings?
  stakeholders   CompanyStakeholder[]
  // Finance domain
  costCenters    CostCenter[]
  bankAccounts   BankAccount[]
  documents      CompanyDocument[]
  financeEntries FinanceEntry[]

  @@unique([cnpjHash, tenantId, deletedAt], name: "companies_cnpj_tenant_unique_active")
  @@index([tenantId])
  @@index([cnpjHash])
  @@index([legalName])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("companies")
}

model CompanyDocument {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  companyId String @map("company_id")

  // Tipo do documento (genérico: "Cartão CNPJ", "Contrato Social", etc.)
  documentType String @map("document_type") @db.VarChar(128)

  // Informações do arquivo (preenchidas após upload)
  fileName String? @map("file_name") @db.VarChar(256)
  fileKey  String? @map("file_key") @db.VarChar(512)
  fileSize Int?    @map("file_size")
  mimeType String? @map("mime_type") @db.VarChar(128)

  // Validade do documento
  expiresAt DateTime? @map("expires_at")

  // Observações (opcional)
  notes String? @db.VarChar(512)

  // Audit
  uploadedBy String?  @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyId])
  @@map("company_documents")
}

model CompanyAddress {
  id String @id @default(uuid())

  companyId    String             @map("company_id")
  type         CompanyAddressType @default(OTHER)
  street       String?            @db.VarChar(256)
  number       String?            @db.VarChar(32)
  complement   String?            @db.VarChar(128)
  district     String?            @db.VarChar(128)
  city         String?            @db.VarChar(128)
  state        String?            @db.VarChar(2)
  zip          String             @db.VarChar(10)
  ibgeCityCode String?            @map("ibge_city_code") @db.VarChar(16)
  countryCode  String?            @default("BR") @map("country_code") @db.VarChar(4)
  isPrimary    Boolean            @default(false) @map("is_primary")

  metadata      Json      @default("{}")
  pendingIssues Json      @default("[]") @map("pending_issues")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, type, deletedAt], name: "company_addresses_company_type_unique_active")
  @@index([companyId])
  @@index([type])
  @@index([zip])
  @@index([isPrimary])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("company_addresses")
}

model CompanyCnae {
  id String @id @default(uuid())

  companyId   String            @map("company_id")
  code        String            @db.VarChar(16)
  description String?           @db.VarChar(256)
  isPrimary   Boolean           @default(false) @map("is_primary")
  status      CompanyCnaeStatus @default(ACTIVE)

  metadata      Json      @default("{}")
  pendingIssues Json      @default("[]") @map("pending_issues")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, code, deletedAt], name: "company_cnaes_company_code_unique_active")
  @@index([companyId])
  @@index([code])
  @@index([isPrimary])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("company_cnaes")
}

model CompanyFiscalSettings {
  id String @id @default(uuid())

  companyId String @unique @map("company_id")

  // NF-e Configuration
  nfeEnvironment            NfeEnvironment? @map("nfe_environment")
  nfeSeries                 String?         @map("nfe_series") @db.VarChar(16)
  nfeLastNumber             Int?            @map("nfe_last_number")
  nfeDefaultOperationNature String?         @map("nfe_default_operation_nature") @db.VarChar(256)
  nfeDefaultCfop            String?         @map("nfe_default_cfop") @db.VarChar(8)

  // Digital Certificate Configuration
  digitalCertificateType DigitalCertificateType @default(NONE) @map("digital_certificate_type")
  certificateA1PfxBlob   Bytes?                 @map("certificate_a1_pfx_blob")
  certificateA1Password  String?                @map("certificate_a1_password")
  certificateA1ExpiresAt DateTime?              @map("certificate_a1_expires_at")

  // NFC-e Configuration
  nfceEnabled  Boolean @default(false) @map("nfce_enabled")
  nfceCscId    String? @map("nfce_csc_id") @db.VarChar(256)
  nfceCscToken String? @map("nfce_csc_token") @db.VarChar(512)

  // Optional Tax Profile reference
  defaultTaxProfileId String? @map("default_tax_profile_id")

  // Metadata
  metadata      Json @default("{}")
  pendingIssues Json @default("[]") @map("pending_issues")

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([digitalCertificateType])
  @@index([nfeEnvironment])
  @@index([nfceEnabled])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("company_fiscal_settings")
}

model CompanyStakeholder {
  id String @id @default(uuid())

  companyId String @map("company_id")

  // Personal Information
  name                 String                  @db.VarChar(256)
  role                 CompanyStakeholderRole? @map("role")
  entryDate            DateTime?               @map("entry_date") @db.Date
  exitDate             DateTime?               @map("exit_date") @db.Date
  personDocumentMasked String?                 @map("person_document_masked") @db.VarChar(256)

  // Legal Information
  isLegalRepresentative Boolean                  @default(false) @map("is_legal_representative")
  status                CompanyStakeholderStatus @default(ACTIVE)

  // Data Source
  source        CompanyStakeholderSource @default(MANUAL)
  rawPayloadRef String?                  @map("raw_payload_ref") @db.VarChar(512)

  // Metadata and Pending Issues
  metadata      Json @default("{}")
  pendingIssues Json @default("[]") @map("pending_issues")

  // Soft Delete with Anonimization
  anonimizedAt DateTime? @map("anonimized_at")
  deletedAt    DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name, role, deletedAt], name: "company_stakeholders_company_name_role_unique_active")
  @@index([companyId])
  @@index([role])
  @@index([status])
  @@index([isLegalRepresentative])
  @@index([source])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("company_stakeholders")
}

// ===============================================
// LABEL TEMPLATES MODULE (Core)
// ===============================================

model LabelTemplate {
  id String @id @default(uuid())

  // Identificação
  name        String  @db.VarChar(255)
  description String? @db.Text

  // Sistema (templates pré-definidos que não podem ser editados/deletados)
  isSystem Boolean @default(false) @map("is_system")

  // Dimensões em milímetros
  width  Int // 10-300mm
  height Int // 10-300mm

  // Dados do GrapesJS (editor de templates)
  grapesJsData String @map("grapes_js_data") @db.Text // JSON do projeto GrapesJS

  // HTML/CSS compilados para impressão
  compiledHtml String? @map("compiled_html") @db.Text
  compiledCss  String? @map("compiled_css") @db.Text

  // Thumbnail gerada
  thumbnailUrl String? @map("thumbnail_url") @db.VarChar(500)

  // Tenant (multi-tenant)
  tenantId String @map("tenant_id")

  // Criado por
  createdById String @map("created_by_id")

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  createdBy User   @relation(fields: [createdById], references: [id])

  @@unique([tenantId, name, deletedAt], name: "label_templates_name_tenant_unique_active")
  @@index([tenantId])
  @@index([isSystem])
  @@index([createdById])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("label_templates")
}

