  embedding         Bytes // AES-256-GCM ciphertext (Float32Array(128) = 512 bytes plaintext)
  iv                Bytes // 12-byte GCM IV
  authTag           Bytes     @map("auth_tag") // 16-byte GCM auth tag
  photoCount        Int       @map("photo_count") // 1..N inside batch (rastreabilidade)
  capturedAt        DateTime  @map("captured_at")
  capturedByUserId  String    @map("captured_by_user_id")
  consentAuditLogId String?   @map("consent_audit_log_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  deletedAt         DateTime? @map("deleted_at")

  @@index([tenantId, employeeId])
  @@map("employee_face_enrollments")
}

// ===============================================
// COMPLIANCE ARTIFACTS — Portaria 671 (Phase 6 / Plan 06-01)
// Registro de cada AFD/AFDT/Folha Espelho/Recibo/S-1200 gerado.
// Armazenamento no R2 via S3FileUploadService; metadata + contentHash
// aqui para histórico + regeneração on-demand.
// ===============================================

model ComplianceArtifact {
  id          String                 @id @default(uuid())
  tenantId    String                 @map("tenant_id")
  type        ComplianceArtifactType
  periodStart DateTime?              @map("period_start")
  periodEnd   DateTime?              @map("period_end")
  competencia String?                @db.VarChar(7) // YYYY-MM (S-1200, Folha Espelho)
  // Filtros aplicados na geração (ex.: { cnpj, departmentIds, employeeId,
  // timeEntryId }). JSON opaco — planner consumer decide shape. Não deve
  // carregar PII verbatim em audit messages (template usa placeholders ID-only).
  filters     Json?
  storageKey  String                 @map("storage_key") // R2 key determinística
  contentHash String                 @map("content_hash") @db.VarChar(64) // SHA-256 hex
  sizeBytes   Int                    @map("size_bytes")
  generatedBy String                 @map("generated_by") // userId (ou 'system' para worker)
  generatedAt DateTime               @default(now()) @map("generated_at")
  deletedAt   DateTime?              @map("deleted_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  generator User   @relation(fields: [generatedBy], references: [id])

  @@index([tenantId, type, generatedAt(sort: Desc)])
  @@index([tenantId, competencia])
  @@index([tenantId, deletedAt])
  @@map("compliance_artifacts")
}

// ===============================================
// COMPLIANCE PUBLIC VERIFY LOG — Audit da rota pública /punch/verify/:nsrHash
// Intencionalmente SEM relation com Tenant/TimeEntry/User — rate-limit
// violations de IP desconhecido não podem quebrar FK quando hash inválido.
// Usado por fase futura (antifraude) para detectar enumeração de hashes.
// ===============================================

model ComplianceVerifyLog {
  id          String   @id @default(uuid())
  nsrHash     String   @map("nsr_hash") @db.VarChar(64)
  tenantId    String?  @map("tenant_id") // NULL quando hash não identifica tenant
  timeEntryId String?  @map("time_entry_id") // NULL em NOT_FOUND / RATE_LIMITED
  ipAddress   String?  @map("ip_address") @db.VarChar(45) // IPv4 ou IPv6
  userAgent   String?  @map("user_agent") @db.Text
  accessedAt  DateTime @default(now()) @map("accessed_at")
  hitResult   String   @map("hit_result") @db.VarChar(16) // FOUND | NOT_FOUND | RATE_LIMITED

  @@index([nsrHash, accessedAt(sort: Desc)])
  @@index([accessedAt(sort: Desc)])
  @@index([tenantId, accessedAt(sort: Desc)])
  @@map("compliance_public_verify_log")
}

model PosPrinter {
