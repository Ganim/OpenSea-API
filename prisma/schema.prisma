  description        String? @db.VarChar(500)
  sampleSize         Int     @default(0) @map("sample_size")
  aqlLevel           String? @map("aql_level") @db.VarChar(16)
  instructions       String? @db.Text
  isActive           Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  operationRouting  ProductionOperationRouting   @relation(fields: [operationRoutingId], references: [id], onDelete: Cascade)
  inspectionResults ProductionInspectionResult[]

  @@index([operationRoutingId])
  @@map("production_inspection_plans")
}

model ProductionInspectionResult {
  id                String           @id @default(cuid())
  inspectionPlanId  String           @map("inspection_plan_id")
  productionOrderId String           @map("production_order_id")
  inspectedById     String           @map("inspected_by_id")
  inspectedAt       DateTime         @default(now()) @map("inspected_at")
  sampleSize        Int              @map("sample_size")
  defectsFound      Int              @default(0) @map("defects_found")
  status            InspectionStatus @default(PENDING)
  notes             String?          @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  inspectionPlan  ProductionInspectionPlan @relation(fields: [inspectionPlanId], references: [id])
  productionOrder ProductionOrder          @relation(fields: [productionOrderId], references: [id])
  defectRecords   ProductionDefectRecord[]

  @@index([inspectionPlanId])
  @@index([productionOrderId])
  @@map("production_inspection_results")
}

model ProductionDefectRecord {
  id                 String         @id @default(cuid())
  inspectionResultId String?        @map("inspection_result_id")
  defectTypeId       String         @map("defect_type_id")
  operatorId         String?        @map("operator_id")
  quantity           Int            @default(1)
  severity           DefectSeverity
  description        String?        @db.VarChar(500)
  imageUrl           String?        @map("image_url") @db.VarChar(512)

  createdAt DateTime @default(now()) @map("created_at")

  inspectionResult ProductionInspectionResult? @relation(fields: [inspectionResultId], references: [id])
  defectType       ProductionDefectType        @relation(fields: [defectTypeId], references: [id])

  @@index([inspectionResultId])
  @@index([defectTypeId])
  @@map("production_defect_records")
}

model ProductionQualityHold {
  id                String            @id @default(cuid())
  productionOrderId String            @map("production_order_id")
  reason            String            @db.VarChar(500)
  status            QualityHoldStatus @default(ACTIVE)
  holdById          String            @map("hold_by_id")
  holdAt            DateTime          @default(now()) @map("hold_at")
  releasedById      String?           @map("released_by_id")
  releasedAt        DateTime?         @map("released_at")
  resolution        String?           @db.VarChar(500)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@index([productionOrderId])
  @@map("production_quality_holds")
}

// --- Custeio (Phase 6) ---

model ProductionCost {
  id                String  @id @default(cuid())
  productionOrderId String  @map("production_order_id")
  costType          String  @map("cost_type") @db.VarChar(32)
  description       String? @db.VarChar(256)
  plannedAmount     Decimal @default(0) @map("planned_amount") @db.Decimal(12, 2)
  actualAmount      Decimal @default(0) @map("actual_amount") @db.Decimal(12, 2)
  varianceAmount    Decimal @default(0) @map("variance_amount") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@index([productionOrderId])
  @@map("production_costs")
}

// ============================================================================
// HR — Contract Templates & Generated Employment Contracts
// ============================================================================

enum ContractTemplateType {
  CLT
  PJ
  INTERN
  TEMPORARY
  EXPERIENCE
  CUSTOM
}

model ContractTemplate {
  id        String               @id @default(cuid())
  tenantId  String               @map("tenant_id")
  name      String               @db.VarChar(256)
  type      ContractTemplateType
  content   String               @db.Text
  isActive  Boolean              @default(true) @map("is_active")
  isDefault Boolean              @default(false) @map("is_default")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant             Tenant                        @relation(fields: [tenantId], references: [id])
  generatedContracts GeneratedEmploymentContract[]

  @@index([tenantId])
  @@index([type])
  @@index([isActive])
  @@index([deletedAt])
  @@map("hr_contract_templates")
}

model GeneratedEmploymentContract {
  id                  String  @id @default(cuid())
  tenantId            String  @map("tenant_id")
  templateId          String  @map("template_id")
  employeeId          String  @map("employee_id")
  storageFileId       String? @map("storage_file_id")
  pdfUrl              String? @map("pdf_url") @db.VarChar(1024)
  pdfKey              String? @map("pdf_key") @db.VarChar(512)
  generatedBy         String  @map("generated_by")
  variables           Json    @default("{}")
  signatureEnvelopeId String? @map("signature_envelope_id")

  createdAt DateTime @default(now()) @map("created_at")

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  template ContractTemplate @relation(fields: [templateId], references: [id])
  employee Employee         @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([templateId])
  @@index([generatedBy])
  @@index([createdAt])
  @@index([signatureEnvelopeId])
  @@map("hr_generated_employment_contracts")
}

// ===============================================
// PUNCH MISSED LOG — Phase 7 / Plan 07-01 (D-12)
// Output do scheduler `detect-missed-punches` (22h timezone-tenant).
// UNIQUE (tenantId, employeeId, date) — idempotente frente a reruns; multi-
// machine dup é defendido em primeira linha por Redis SETNX no scheduler
// (Pitfall 3 do 07-RESEARCH).
// ===============================================

model PunchMissedLog {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  employeeId        String    @map("employee_id")
  date              DateTime  @db.Date
  shiftAssignmentId String?   @map("shift_assignment_id")
  expectedStartTime DateTime? @map("expected_start_time")
  expectedEndTime   DateTime? @map("expected_end_time")
  generatedAt       DateTime  @default(now()) @map("generated_at")
  generatedByJobId  String?   @map("generated_by_job_id")
  // Phase 9 (recuperação): funcionário bate depois OU ajuste manual OU licença
  // justificada posterior. Em Phase 7 permanece `null`.
  resolvedAt        DateTime? @map("resolved_at")
  resolutionType    String?   @map("resolution_type") @db.VarChar(30)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, date])
  @@index([tenantId, date])
  @@index([employeeId, date])
  @@map("punch_missed_logs")
}
