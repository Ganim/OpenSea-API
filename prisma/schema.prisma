  documentUrl    String?   @map("document_url")

  // PCMSO / Occupational Health fields
  examCategory   String?   @map("exam_category") @db.VarChar(32) // ADMISSIONAL, PERIODICO, RETORNO, MUDANCA_FUNCAO, DEMISSIONAL
  validityMonths Int?      @map("validity_months")
  clinicName     String?   @map("clinic_name") @db.VarChar(256)
  clinicAddress  String?   @map("clinic_address") @db.VarChar(512)
  physicianName  String?   @map("physician_name") @db.VarChar(256) // Coordinating physician (PCMSO)
  physicianCRM   String?   @map("physician_crm") @db.VarChar(32)
  aptitude       String?   @db.VarChar(32) // APTO, INAPTO, APTO_COM_RESTRICOES
  // DEPRECATED (P0-12): kept for backfill; encrypted copy lives in
  // restrictionsEncrypted.
  restrictions   String?   @db.Text
  nextExamDate   DateTime? @map("next_exam_date")

  // ---- Sensitive health data (encrypted at rest — P0-12) ----
  // AES-256-GCM base64 blobs (IV + AuthTag + Ciphertext bundled).
  // Read path decrypts only when the caller has HR.MEDICAL_EXAMS.ADMIN.
  observationsEncrypted String? @map("observations_encrypted")
  restrictionsEncrypted String? @map("restrictions_encrypted")

  // ---- NR-7 retention (P0-02) ----
  // ASO records must be retained for 20 years after the employee leaves
  // the company (NR-7 item 7.4.4.3). Instead of hard-deleting, flag with
  // deletedAt and enforce purge-only-after-20-years business rule at the
  // application layer.
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([tenantId])
  @@index([employeeId])
  @@index([type])
  @@index([examDate])
  @@index([expirationDate])
  @@index([aptitude])
  @@index([deletedAt])
  @@index([tenantId, deletedAt])
  @@map("medical_exams")
}

// ===============================================
// OCCUPATIONAL EXAM REQUIREMENTS (PCMSO)
// ===============================================

model OccupationalExamRequirement {
  id              String  @id @default(uuid())
  tenantId        String  @map("tenant_id")
  positionId      String? @map("position_id")
  examType        String  @map("exam_type") @db.VarChar(64) // AUDIOMETRIA, ESPIROMETRIA, ACUIDADE_VISUAL, HEMOGRAMA, etc.
  examCategory    String  @map("exam_category") @db.VarChar(32) // ADMISSIONAL, PERIODICO, etc.
  frequencyMonths Int     @map("frequency_months")
  isMandatory     Boolean @default(true) @map("is_mandatory")
  description     String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  position Position? @relation(fields: [positionId], references: [id])

  @@index([tenantId])
  @@index([positionId])
  @@index([examCategory])
  @@map("occupational_exam_requirements")
}

// ===============================================
// SAFETY PROGRAMS (PCMSO/PGR) — NR-1, NR-7
// ===============================================

model SafetyProgram {
  id                      String   @id @default(uuid())
  tenantId                String   @map("tenant_id")
  type                    String   @db.VarChar(16) // PCMSO, PGR, LTCAT, PPRA (legacy)
  name                    String   @db.VarChar(256)
  validFrom               DateTime @map("valid_from")
  validUntil              DateTime @map("valid_until")
  responsibleName         String   @map("responsible_name") @db.VarChar(256)
  responsibleRegistration String   @map("responsible_registration") @db.VarChar(64) // CRM, CREA
  documentUrl             String?  @map("document_url")
  status                  String   @default("ACTIVE") @db.VarChar(16) // ACTIVE, EXPIRED, DRAFT
  notes                   String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  risks  WorkplaceRisk[]

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([validFrom])
  @@index([validUntil])
  @@map("safety_programs")
}

model WorkplaceRisk {
  id              String @id @default(uuid())
  tenantId        String @map("tenant_id")
  safetyProgramId String @map("safety_program_id")

  name            String  @db.VarChar(256) // e.g., "Ruído", "Químico", "Ergonômico"
  category        String  @db.VarChar(32) // FISICO, QUIMICO, BIOLOGICO, ERGONOMICO, ACIDENTE
  severity        String  @db.VarChar(16) // BAIXO, MEDIO, ALTO, CRITICO
  source          String? @db.VarChar(256) // e.g., "Máquina de corte", "Produto químico X"
  affectedArea    String? @map("affected_area") @db.VarChar(256) // e.g., "Galpão de produção"
  controlMeasures String? @map("control_measures") // Medidas de controle existentes
  epiRequired     String? @map("epi_required") // EPIs necessários (luva, capacete, etc.)
  isActive        Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  safetyProgram SafetyProgram @relation(fields: [safetyProgramId], references: [id])

  @@index([tenantId])
  @@index([safetyProgramId])
  @@index([category])
  @@index([severity])
  @@map("workplace_risks")
}

// ===============================================
// CIPA (NR-5) — Comissão Interna de Prevenção de Acidentes
// ===============================================

model CipaMandate {
  id           String    @id @default(uuid())
  tenantId     String    @map("tenant_id")
  name         String    @db.VarChar(256) // e.g., "CIPA 2026/2027"
  startDate    DateTime  @map("start_date")
  endDate      DateTime  @map("end_date") // Typically 1 year
  status       String    @default("ACTIVE") @db.VarChar(16) // ACTIVE, EXPIRED, DRAFT
  electionDate DateTime? @map("election_date")
  notes        String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  members CipaMember[]

  @@index([tenantId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@map("cipa_mandates")
