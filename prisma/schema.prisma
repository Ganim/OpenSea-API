// ===============================================
// COMPLIANCE — Portaria MTP 671/2021 (Phase 6)
// Plan 06-01: Schema base para AFD/AFDT/Folha Espelho/Recibo/S-1200
// ===============================================

/**
 * Tipos de artefato de compliance registrados em `compliance_artifacts`.
 * - AFD:           Arquivo Fonte de Dados (layout oficial Portaria 671
 * Anexo I; registros tipo 1..5, 7, 9 byte-a-byte).
 * - AFDT:          Arquivo Fonte de Dados Tratado (produto proprietário
 * OpenSea; inclui linhas de ajuste via adjustmentType).
 * Ver D-05 em 06-CONTEXT.md — AEJ fica Deferred.
 * - FOLHA_ESPELHO: PDF CLT mensal por funcionário/competência.
 * - RECIBO:        PDF A6 por batida com QR para consulta pública.
 * - S1200_XML:     XML eSocial S-1200 por competência/funcionário.
 */
enum ComplianceArtifactType {
  AFD
  AFDT
  FOLHA_ESPELHO
  RECIBO
  S1200_XML
}

/**
 * Discriminador de semântica das linhas de `TimeEntry` (D-01 — AFDT ajuste
 * como linha nova com NSR sequencial próprio).
 * - ORIGINAL:             Batida crua capturada pelo kiosk/PWA. NSR
 * sequencial; jamais mutada. `originNsrNumber = NULL`.
 * - ADJUSTMENT_APPROVED:  Nova linha gerada quando gestor aprova correção
 * via PunchApproval. `originNsrNumber` aponta para
 * o NSR da batida original (sempre < nsrNumber atual).
 * No AFDT, aparece como registro tipo 4 referenciando
 * o NSR original.
 */
enum AdjustmentType {
  ORIGINAL
  ADJUSTMENT_APPROVED
}

