// ============================================================================
// CONTRACTS - Contratos de Serviço
// ============================================================================

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  RENEWED
  CANCELLED
}

model Contract {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  code        String  @db.VarChar(32)
  title       String  @db.VarChar(256)
  description String? @db.Text

  status ContractStatus @default(ACTIVE)

  // Parties
  companyId    String? @map("company_id")
  companyName  String  @map("company_name") @db.VarChar(256)
  contactName  String? @map("contact_name") @db.VarChar(128)
  contactEmail String? @map("contact_email") @db.VarChar(256)

  // Financial
  totalValue       Decimal        @map("total_value") @db.Decimal(15, 2)
  paymentFrequency RecurrenceUnit @map("payment_frequency")
  paymentAmount    Decimal        @map("payment_amount") @db.Decimal(15, 2)
  categoryId       String?        @map("category_id")
  costCenterId     String?        @map("cost_center_id")
  bankAccountId    String?        @map("bank_account_id")

  // Dates & Renewal
  startDate           DateTime @map("start_date")
  endDate             DateTime @map("end_date")
  autoRenew           Boolean  @default(false) @map("auto_renew")
  renewalPeriodMonths Int?     @map("renewal_period_months")
  alertDaysBefore     Int      @default(30) @map("alert_days_before")

  // File management
  folderPath String? @map("folder_path") @db.VarChar(512)

  notes    String? @db.Text
  metadata Json    @default("{}")

  createdBy String?   @map("created_by")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([code, tenantId, deletedAt], name: "contracts_code_tenant_unique_active")
  @@index([tenantId])
  @@index([status])
  @@index([companyId])
  @@index([endDate])
  @@index([deletedAt])
  @@index([tenantId, status])
  @@map("contracts")
}

