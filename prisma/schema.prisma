  resultStatus MockupResultStatus @default(PENDING) @map("result_status")
  generatedAt  DateTime?          @map("generated_at")

  // Usage
  bidId      String? @map("bid_id")
  orderId    String? @map("order_id")
  proposalId String? @map("proposal_id")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  variant        Variant          @relation(fields: [variantId], references: [id])
  clientLogo     StorageFile?     @relation("MockupClientLogo", fields: [clientLogoFileId], references: [id])
  resultFile     StorageFile?     @relation("MockupResultFile", fields: [resultFileId], references: [id])
  mockupTemplate ContentTemplate? @relation(fields: [mockupTemplateId], references: [id])

  @@index([tenantId])
  @@index([tenantId, variantId])
  @@index([bidId])
  @@index([orderId])
  @@map("product_mockups")
}

model EmailCampaign {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  name        String              @db.VarChar(128)
  type        EmailCampaignType
  status      EmailCampaignStatus @default(DRAFT)
  subject     String              @db.VarChar(256)
  previewText String?             @map("preview_text") @db.VarChar(256)
  content     String              @db.Text

  templateId String? @map("template_id")
  brandId    String? @map("brand_id")

  // Recipients
  recipientType   EmailRecipientType @map("recipient_type")
  recipientFilter Json?              @map("recipient_filter")
  recipientCount  Int                @default(0) @map("recipient_count")

  // Schedule
  scheduledAt DateTime? @map("scheduled_at")
  sentAt      DateTime? @map("sent_at")

  // Products featured
  variantIds String[] @default([]) @map("variant_ids")
  campaignId String?  @map("campaign_id")
  catalogId  String?  @map("catalog_id")

  // AI
  aiGenerated Boolean @default(false) @map("ai_generated")
  aiPrompt    String? @map("ai_prompt") @db.Text

  // Metrics
  totalSent         Int      @default(0) @map("total_sent")
  totalOpened       Int      @default(0) @map("total_opened")
  totalClicked      Int      @default(0) @map("total_clicked")
  totalBounced      Int      @default(0) @map("total_bounced")
  totalUnsubscribed Int      @default(0) @map("total_unsubscribed")
  openRate          Decimal? @map("open_rate") @db.Decimal(5, 2)
  clickRate         Decimal? @map("click_rate") @db.Decimal(5, 2)

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  template ContentTemplate? @relation(fields: [templateId], references: [id])
  brand    TenantBrand?     @relation(fields: [brandId], references: [id])
  campaign Campaign?        @relation(fields: [campaignId], references: [id])
  catalog  Catalog?         @relation(fields: [catalogId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("email_campaigns")
}

// ===============================================
// ORDERS MODULE
// ===============================================

// --- Orders Enums ---

enum OrderType {
  QUOTE
  ORDER
}

enum OrderChannel {
  PDV
  WEB
  WHATSAPP
  MARKETPLACE
  BID
  MANUAL
  API
}

enum DeliveryMethod {
  PICKUP
  OWN_FLEET
  CARRIER
  PARTIAL
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BOLETO
  BANK_TRANSFER
  CHECK
  STORE_CREDIT
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentConditionType {
  CASH
  INSTALLMENT
  CUSTOM
  CREDIT_LIMIT
}

enum PaymentConditionApplicable {
  ALL
  RETAIL
  WHOLESALE
  BID
}

enum InterestType {
  SIMPLE
  COMPOUND
}

enum DeliveryStatus {
  PREPARING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum ReturnType {
  FULL_RETURN
  PARTIAL_RETURN
  EXCHANGE
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  RECEIVING
  RECEIVED
  CREDIT_ISSUED
  EXCHANGE_COMPLETED
  REJECTED
  CANCELLED
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  CHANGED_MIND
  DAMAGED
  NOT_AS_DESCRIBED
  OTHER
}

enum ReturnItemCondition {
  NEW
  USED
  DAMAGED
  DEFECTIVE
}

enum RefundMethod {
  SAME_METHOD
  STORE_CREDIT
  BANK_TRANSFER
  PIX
}

enum StoreCreditSource {
  RETURN
  MANUAL
  CAMPAIGN
  LOYALTY
}

enum ApprovalRuleType {
  ORDER_VALUE
  DISCOUNT_PERCENT
  CREDIT_EXCEEDED
  NEW_CUSTOMER
  MANUAL_PRICE
  CUSTOM
}

enum CommissionType {
  PERCENTAGE
  FIXED_PER_ORDER
  FIXED_PER_ITEM
  TIERED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum CommissionAppliesTo {
  ALL
  SPECIFIC_USERS
  SPECIFIC_CATEGORIES
  SPECIFIC_PRODUCTS
}

enum OrderHistoryAction {
  CREATED
  STAGE_CHANGED
  ITEM_ADDED
  ITEM_REMOVED
  ITEM_MODIFIED
  PAYMENT_ADDED
  PAYMENT_RECEIVED
  APPROVAL_REQUESTED
  APPROVED
  REJECTED
  DELIVERY_CREATED
  DELIVERY_SHIPPED
  DELIVERY_COMPLETED
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURN_COMPLETED
  CANCELLED
  NOTE_ADDED
  ASSIGNED
  COUPON_APPLIED
}

enum PriceSourceType {
  CUSTOMER
  CAMPAIGN
  COUPON
  QUANTITY_TIER
  TABLE
  DEFAULT
  MANUAL
}

// --- Orders Models ---

model Order {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  orderNumber String      @map("order_number") @db.VarChar(64)
  type        OrderType
  status      OrderStatus @default(DRAFT)

  // Relations FKs
  customerId String  @map("customer_id")
  contactId  String? @map("contact_id")
  pipelineId String  @map("pipeline_id")
  stageId    String  @map("stage_id")

  channel OrderChannel

  // Pricing
  subtotal      Decimal @db.Decimal(12, 2)
  discountTotal Decimal @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal      Decimal @default(0) @map("tax_total") @db.Decimal(12, 2)
  shippingTotal Decimal @default(0) @map("shipping_total") @db.Decimal(12, 2)
  grandTotal    Decimal @map("grand_total") @db.Decimal(12, 2)
  currency      String  @default("BRL") @db.VarChar(3)
  priceTableId  String? @map("price_table_id")

  // Payment
  paymentConditionId String? @map("payment_condition_id")
  creditUsed         Decimal @default(0) @map("credit_used") @db.Decimal(12, 2)
  paidAmount         Decimal @default(0) @map("paid_amount") @db.Decimal(12, 2)
  remainingAmount    Decimal @map("remaining_amount") @db.Decimal(12, 2)

  // Delivery
  deliveryMethod    DeliveryMethod? @map("delivery_method")
  deliveryAddress   Json?           @map("delivery_address")
  trackingCode      String?         @map("tracking_code")
  carrierName       String?         @map("carrier_name")
  estimatedDelivery DateTime?       @map("estimated_delivery")
  deliveredAt       DateTime?       @map("delivered_at")

  // Approval
  needsApproval    Boolean   @default(false) @map("needs_approval")
  approvedByUserId String?   @map("approved_by_user_id")
  approvedAt       DateTime? @map("approved_at")
  approvalNotes    String?   @map("approval_notes")
  rejectedReason   String?   @map("rejected_reason")

  // External References
  dealId         String? @map("deal_id")
  quoteId        String? @map("quote_id")
  returnOriginId String? @map("return_origin_id")
  couponId       String? @map("coupon_id")

  // Warehouse
  sourceWarehouseId String? @map("source_warehouse_id")

  // Assignment
  assignedToUserId String? @map("assigned_to_user_id")

  // Metadata
  notes          String?   @db.Text
  internalNotes  String?   @map("internal_notes") @db.Text
  tags           String[]  @default([])
  customFields   Json?     @map("custom_fields")
  stageEnteredAt DateTime  @map("stage_entered_at")
  confirmedAt    DateTime? @map("confirmed_at")
  cancelledAt    DateTime? @map("cancelled_at")
  cancelReason   String?   @map("cancel_reason")
  expiresAt      DateTime? @map("expires_at")

  // PDV fields
  saleCode        String?   @map("sale_code") @db.VarChar(8)
  terminalId      String?   @map("terminal_id") // Terminal de origem da venda (mode-aware cashier queue)
  cashierUserId   String?   @map("cashier_user_id")
  posSessionId    String?   @map("pos_session_id")
  claimedByUserId String?   @map("claimed_by_user_id")
  claimedAt       DateTime? @map("claimed_at")
  version         Int       @default(1)

  // NF-e fields
  invoiceId  String?   @map("invoice_id")
  invoicedAt DateTime? @map("invoiced_at")

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  customer         Customer          @relation(fields: [customerId], references: [id])
  contact          CrmContact?       @relation(fields: [contactId], references: [id])
  pipeline         CrmPipeline       @relation(fields: [pipelineId], references: [id])
  stage            CrmPipelineStage  @relation(fields: [stageId], references: [id])
  priceTable       PriceTable?       @relation(fields: [priceTableId], references: [id])
  paymentCondition PaymentCondition? @relation(fields: [paymentConditionId], references: [id])
  quote            Order?            @relation("OrderQuote", fields: [quoteId], references: [id])
  convertedOrders  Order[]           @relation("OrderQuote")
  returnOrigin     Order?            @relation("OrderReturn", fields: [returnOriginId], references: [id])
  returnedOrders   Order[]           @relation("OrderReturn")
  coupon           Coupon?           @relation(fields: [couponId], references: [id])
  sourceWarehouse  Warehouse?        @relation(fields: [sourceWarehouseId], references: [id])
  assignedTo       User?             @relation("OrderAssignee", fields: [assignedToUserId], references: [id])
  approvedBy       User?             @relation("OrderApprover", fields: [approvedByUserId], references: [id])

  items       OrderItem[]
  payments    OrderPayment[]
  deliveries  OrderDelivery[]
  returns     OrderReturn[]
  commissions OrderCommission[]
  history     OrderHistory[]

  // Reverse relations
  storeCreditsReserved StoreCredit[]      @relation("StoreCreditReservedOrder")
  storeCreditUsages    StoreCreditUsage[]

  // PDV Relations
  cashierUser   User?        @relation("OrderCashier", fields: [cashierUserId], references: [id])
  posSession    PosSession?  @relation(fields: [posSessionId], references: [id])
  claimedByUser User?        @relation("OrderClaimedBy", fields: [claimedByUserId], references: [id])
  terminal      PosTerminal? @relation("OrderTerminal", fields: [terminalId], references: [id])

  // POS Relations
  posTransactions PosTransaction[]
  posVisitLogs    PosVisitLog[]

  // Invoicing Relations
  invoice Invoice?

  // Fiscal Relations
  fiscalDocuments FiscalDocument[]

  // Payment Gateway Relations
  paymentCharges PaymentCharge[]

  @@unique([tenantId, orderNumber])
  @@unique([tenantId, saleCode])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, customerId])
  @@index([tenantId, assignedToUserId])
  @@index([tenantId, stageId])
  @@index([tenantId, pipelineId])
  @@index([tenantId, channel])
  @@index([tenantId, createdAt])
  @@index([tenantId, channel, status, createdAt])
  @@index([tenantId, assignedToUserId, status])
  @@map("orders")
}

model OrderItem {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  orderId  String @map("order_id")

  variantId String? @map("variant_id")
  comboId   String? @map("combo_id")

  // Description (snapshot)
  name        String  @db.VarChar(256)
  sku         String? @db.VarChar(64)
  description String? @db.Text

  // Pricing (snapshot at time of sale)
  quantity        Decimal @db.Decimal(10, 3)
  unitPrice       Decimal @map("unit_price") @db.Decimal(10, 2)
  discountPercent Decimal @default(0) @map("discount_percent") @db.Decimal(5, 2)
  discountValue   Decimal @default(0) @map("discount_value") @db.Decimal(10, 2)
  subtotal        Decimal @db.Decimal(12, 2)

  // Tax (calculated)
  taxIcms   Decimal @default(0) @map("tax_icms") @db.Decimal(10, 2)
  taxIpi    Decimal @default(0) @map("tax_ipi") @db.Decimal(10, 2)
  taxPis    Decimal @default(0) @map("tax_pis") @db.Decimal(10, 2)
  taxCofins Decimal @default(0) @map("tax_cofins") @db.Decimal(10, 2)
  taxTotal  Decimal @default(0) @map("tax_total") @db.Decimal(10, 2)
  ncm       String? @db.VarChar(10)
  cfop      String? @db.VarChar(8)

  // Fulfillment
  quantityDelivered Decimal @default(0) @map("quantity_delivered") @db.Decimal(10, 3)
  quantityReturned  Decimal @default(0) @map("quantity_returned") @db.Decimal(10, 3)

  // Pricing source (for audit)
  priceSource   PriceSourceType @default(DEFAULT) @map("price_source")
  priceSourceId String?         @map("price_source_id")

  position Int     @default(0)
  notes    String? @db.Text

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant? @relation(fields: [variantId], references: [id])
  combo   Combo?   @relation(fields: [comboId], references: [id])

  deliveryItems OrderDeliveryItem[]
  returnItems   OrderReturnItem[]

  @@index([orderId])
  @@index([tenantId])
  @@index([orderId, variantId])
  @@map("order_items")
}

model PaymentCondition {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  name        String               @db.VarChar(128)
  description String?
  type        PaymentConditionType

  installments       Int          @default(1)
  firstDueDays       Int          @default(0) @map("first_due_days")
  intervalDays       Int          @default(30) @map("interval_days")
  downPaymentPercent Decimal?     @map("down_payment_percent") @db.Decimal(5, 2)
  interestRate       Decimal?     @map("interest_rate") @db.Decimal(5, 2)
  interestType       InterestType @default(SIMPLE) @map("interest_type")
  penaltyRate        Decimal?     @map("penalty_rate") @db.Decimal(5, 2)
  discountCash       Decimal?     @map("discount_cash") @db.Decimal(5, 2)

  // Rules
  applicableTo  PaymentConditionApplicable @default(ALL) @map("applicable_to")
  minOrderValue Decimal?                   @map("min_order_value") @db.Decimal(10, 2)
  maxOrderValue Decimal?                   @map("max_order_value") @db.Decimal(10, 2)

  isActive  Boolean @default(true) @map("is_active")
  isDefault Boolean @default(false) @map("is_default")

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant  @relation(fields: [tenantId], references: [id])
  orders Order[]

