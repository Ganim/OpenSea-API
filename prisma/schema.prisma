  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, fromUnit, toUnit])
  @@index([variantId])
  @@map("unit_conversions")
}

// --- Sistema de Snapshots de Estoque ---

model StockSnapshot {
