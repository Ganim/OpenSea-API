  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("bid_ai_configs")
}

model CertidaoSchedule {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  type          BidDocumentType
  renewalUrl    String?             @map("renewal_url") @db.VarChar(1024)
  renewalMethod BidDocRenewalMethod @map("renewal_method")

  lastCheck      DateTime? @map("last_check")
  lastRenewal    DateTime? @map("last_renewal")
  nextExpiration DateTime? @map("next_expiration")

  checkIntervalDays Int     @default(7) @map("check_interval_days")
  alertDaysBefore   Int     @default(15) @map("alert_days_before")
