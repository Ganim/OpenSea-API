  doctorName     String    @map("doctor_name") @db.VarChar(256)
  doctorCrm      String    @map("doctor_crm") @db.VarChar(32)
  result         String    @db.VarChar(32) // APTO, INAPTO, APTO_COM_RESTRICOES
  // DEPRECATED (P0-12): kept for backfill; encrypted copy lives in
  // observationsEncrypted. Will be dropped in a follow-up migration once
  // all historical rows have been re-encrypted.
