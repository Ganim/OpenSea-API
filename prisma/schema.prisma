// ============================================================================
// BANK RECONCILIATION - Conciliação Bancária (OFX Import)
// ============================================================================

model BankReconciliation {
  id            String @id @default(uuid())
  tenantId      String @map("tenant_id")
  bankAccountId String @map("bank_account_id")

  importDate  DateTime @default(now()) @map("import_date")
  fileName    String   @map("file_name") @db.VarChar(256)
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")

  totalTransactions Int @default(0) @map("total_transactions")
  matchedCount      Int @default(0) @map("matched_count")
  unmatchedCount    Int @default(0) @map("unmatched_count")

  status ReconciliationStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  items BankReconciliationItem[]

  @@index([tenantId])
  @@index([bankAccountId])
  @@index([status])
  @@map("bank_reconciliations")
}

model BankReconciliationItem {
  id               String @id @default(uuid())
  reconciliationId String @map("reconciliation_id")

  fitId           String   @map("fit_id") @db.VarChar(64)
  transactionDate DateTime @map("transaction_date")
  amount          Decimal  @db.Decimal(12, 2)
  description     String   @db.VarChar(512)
  type            String   @db.VarChar(16) // DEBIT or CREDIT

  matchedEntryId  String?                   @map("matched_entry_id")
  matchConfidence Float?                    @map("match_confidence")
  matchStatus     ReconciliationMatchStatus @default(UNMATCHED) @map("match_status")

  createdAt DateTime @default(now()) @map("created_at")

  reconciliation BankReconciliation         @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  matchedEntry   FinanceEntry?              @relation(fields: [matchedEntryId], references: [id])
  suggestions    ReconciliationSuggestion[]

  @@unique([reconciliationId, fitId])
  @@index([reconciliationId])
  @@index([matchedEntryId])
  @@index([matchStatus])
  @@map("bank_reconciliation_items")
}

model ReconciliationSuggestion {
  id            String                         @id @default(uuid())
  tenantId      String                         @map("tenant_id")
  transactionId String                         @map("transaction_id")
  entryId       String                         @map("entry_id")
  score         Int
  matchReasons  String[]                       @map("match_reasons")
  status        ReconciliationSuggestionStatus @default(PENDING)
  reviewedAt    DateTime?                      @map("reviewed_at")
  reviewedBy    String?                        @map("reviewed_by")
  createdAt     DateTime                       @default(now()) @map("created_at")

  tenant      Tenant                 @relation(fields: [tenantId], references: [id])
  transaction BankReconciliationItem @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  entry       FinanceEntry           @relation("ReconciliationSuggestionEntry", fields: [entryId], references: [id])

  @@index([tenantId])
  @@index([transactionId])
  @@index([entryId])
  @@index([status])
  @@map("reconciliation_suggestions")
}

// ============================================================================
