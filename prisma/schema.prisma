model CipaMember {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  mandateId   String    @map("mandate_id")
  employeeId  String    @map("employee_id")
  role        String    @db.VarChar(32) // PRESIDENTE, VICE_PRESIDENTE, SECRETARIO, MEMBRO_TITULAR, MEMBRO_SUPLENTE
  type        String    @db.VarChar(16) // EMPREGADOR (appointed), EMPREGADO (elected)
  isStable    Boolean   @default(false) @map("is_stable") // Elected members have job stability
  stableUntil DateTime? @map("stable_until") // mandate end + 1 year for elected members

