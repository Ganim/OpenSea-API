  requireApproval  Boolean            @default(true) @map("require_approval")
  employerType     String             @default("CNPJ") @map("employer_type") @db.VarChar(8) // CNPJ or CPF
  employerDocument String?            @map("employer_document") @db.VarChar(18)

  // Plan 06-05 D-06 — Número INPI para cabeçalho AFD (Portaria 671 Anexo I tipo 1).
  // Nullable: tenants sem registro INPI real usam placeholder '99999999999999999'
  // (convenção REP-A aceita pelo Validador MTP). UI em Plan 06-06 deve expor esse
  // campo com label de ajuda.
  inpiNumber String? @map("inpi_number") @db.VarChar(17)

