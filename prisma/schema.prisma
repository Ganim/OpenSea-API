  type            String   @db.VarChar(32) // SEM_JUSTA_CAUSA, JUSTA_CAUSA, PEDIDO_DEMISSAO, ACORDO_MUTUO, CONTRATO_TEMPORARIO, RESCISAO_INDIRETA, FALECIMENTO
