  minMarginPercent Decimal  @default(10) @map("min_margin_percent") @db.Decimal(6, 2)

  allowedModalities String[] @default([]) @map("allowed_modalities")
  allowedCategories String[] @default([]) @map("allowed_categories")
  blockedOrgans     String[] @default([]) @map("blocked_organs")

  maxSimultaneous      Int      @default(10) @map("max_simultaneous")
  maxAggregateExposure Decimal? @map("max_aggregate_exposure") @db.Decimal(14, 2)
  coolingOffMinutes    Int      @default(30) @map("cooling_off_minutes")

  emergencyStop         Boolean @default(false) @map("emergency_stop")
  firstTimeApproval     Boolean @default(true) @map("first_time_approval")
  companySize           String? @map("company_size") @db.VarChar(16)
  monitoringTimeoutDays Int     @default(180) @map("monitoring_timeout_days")

  // Auto-action flags
  autoProspect    Boolean @default(false) @map("auto_prospect")
  autoPropose     Boolean @default(false) @map("auto_propose")
  autoDispute     Boolean @default(false) @map("auto_dispute")
  autoRespond     Boolean @default(false) @map("auto_respond")
  autoCreateOrder Boolean @default(false) @map("auto_create_order")

  notifyOnActions       Boolean  @default(true) @map("notify_on_actions")
  chatResponseWhitelist String[] @default([]) @map("chat_response_whitelist")

