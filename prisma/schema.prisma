// ============================================================================
// FINANCE - Overdue Escalation Automation
// ============================================================================

enum EscalationChannel {
  EMAIL
  WHATSAPP
  INTERNAL_NOTE
  SYSTEM_ALERT
}

enum EscalationTemplateType {
  FRIENDLY_REMINDER
  FORMAL_NOTICE
  URGENT_NOTICE
  FINAL_NOTICE
}

enum EscalationActionStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model OverdueEscalation {
  id        String  @id @default(uuid())
  tenantId  String  @map("tenant_id")
  name      String  @db.VarChar(128)
  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant                  @relation(fields: [tenantId], references: [id])
  steps  OverdueEscalationStep[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("overdue_escalations")
}

model OverdueEscalationStep {
  id           String                 @id @default(uuid())
  escalationId String                 @map("escalation_id")
  daysOverdue  Int                    @map("days_overdue")
  channel      EscalationChannel
  templateType EscalationTemplateType @map("template_type")
  subject      String?                @db.VarChar(256)
  message      String                 @db.Text
  isActive     Boolean                @default(true) @map("is_active")
  order        Int

  escalation     OverdueEscalation @relation(fields: [escalationId], references: [id], onDelete: Cascade)
  overdueActions OverdueAction[]

  @@unique([escalationId, daysOverdue, channel])
  @@index([escalationId])
  @@map("overdue_escalation_steps")
}

model OverdueAction {
  id       String                 @id @default(uuid())
  tenantId String                 @map("tenant_id")
  entryId  String                 @map("entry_id")
  stepId   String?                @map("step_id")
  channel  EscalationChannel
  status   EscalationActionStatus @default(PENDING)
  sentAt   DateTime?              @map("sent_at")
  error    String?                @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant                 @relation(fields: [tenantId], references: [id])
  entry  FinanceEntry           @relation(fields: [entryId], references: [id])
  step   OverdueEscalationStep? @relation(fields: [stepId], references: [id])

  // P2-08: two concurrent overdue cron workers could both check-then-create
  // a duplicate action. The use case still performs the "is there already
  // an action" check for the fast path, but a DB-level unique constraint
  // guarantees that at most one action per escalation step per entry per
  // tenant ever exists — the loser races with P2002 and is caught & skipped.
  @@unique([tenantId, entryId, stepId])
  @@index([tenantId])
  @@index([entryId])
  @@index([stepId])
  @@map("overdue_actions")
}

