  @@index([tenantId, startDate, endDate])
  @@index([tenantId, type])
  @@index([calendarId])
  @@index([createdBy])
  @@index([systemSourceType, systemSourceId])
  @@index([deletedAt])
  @@map("calendar_events")
}

model EventParticipant {
  id          String            @id @default(uuid())
  tenantId    String            @map("tenant_id")
  eventId     String            @map("event_id")
  userId      String            @map("user_id")
  role        ParticipantRole   @default(GUEST)
  status      ParticipantStatus @default(PENDING)
  respondedAt DateTime?         @map("responded_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  event  CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@index([tenantId])
  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@map("event_participants")
}

model EventReminder {
  id            String    @id @default(uuid())
  tenantId      String    @map("tenant_id")
  eventId       String    @map("event_id")
  userId        String    @map("user_id")
  minutesBefore Int       @map("minutes_before")
  isSent        Boolean   @default(false) @map("is_sent")
  sentAt        DateTime? @map("sent_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  event  CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@unique([eventId, userId, minutesBefore])
  @@index([tenantId])
  @@index([eventId])
  @@index([userId])
  @@index([isSent, eventId])
  @@map("event_reminders")
}

// EMAIL MODULE

enum EmailAccountVisibility {
  PRIVATE
  SHARED

  @@map("email_account_visibility")
}

enum EmailFolderType {
  INBOX
  SENT
  DRAFTS
  TRASH
  SPAM
  CUSTOM

  @@map("email_folder_type")
}

model EmailAccount {
  id              String                 @id @default(uuid())
  tenantId        String                 @map("tenant_id")
  ownerUserId     String                 @map("owner_user_id")
  address         String                 @db.VarChar(256)
  displayName     String?                @map("display_name") @db.VarChar(128)
  imapHost        String                 @map("imap_host") @db.VarChar(256)
  imapPort        Int                    @map("imap_port")
  imapSecure      Boolean                @default(true) @map("imap_secure")
  smtpHost        String                 @map("smtp_host") @db.VarChar(256)
  smtpPort        Int                    @map("smtp_port")
  smtpSecure      Boolean                @default(true) @map("smtp_secure")
  tlsVerify       Boolean                @default(false) @map("tls_verify")
  username        String                 @db.VarChar(256)
  encryptedSecret String                 @map("encrypted_secret") @db.Text
  visibility      EmailAccountVisibility @default(PRIVATE)
  isActive        Boolean                @default(true) @map("is_active")
  isDefault       Boolean                @default(false) @map("is_default")
  signature       String?                @db.Text
  lastSyncAt      DateTime?              @map("last_sync_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  tenant    Tenant               @relation(fields: [tenantId], references: [id])
  owner     User                 @relation(fields: [ownerUserId], references: [id])
  access    EmailAccountAccess[]
  teamLinks TeamEmailAccount[]
  folders   EmailFolder[]
  messages  EmailMessage[]

  @@unique([tenantId, address])
  @@index([tenantId])
  @@index([ownerUserId])
  @@index([tenantId, isActive])
  @@map("email_accounts")
}

model EmailAccountAccess {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  canRead   Boolean  @default(true) @map("can_read")
  canSend   Boolean  @default(false) @map("can_send")
  canManage Boolean  @default(false) @map("can_manage")
  createdAt DateTime @default(now()) @map("created_at")

  account EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  user    User         @relation(fields: [userId], references: [id])

  @@unique([accountId, userId])
  @@index([tenantId])
  @@index([userId])
  @@map("email_account_access")
}

model EmailFolder {
  id          String          @id @default(uuid())
  accountId   String          @map("account_id")
  remoteName  String          @map("remote_name") @db.VarChar(256)
  displayName String          @map("display_name") @db.VarChar(128)
  type        EmailFolderType @default(CUSTOM)
  uidValidity Int?            @map("uid_validity")
  lastUid     Int?            @map("last_uid")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  account  EmailAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages EmailMessage[]

  @@unique([accountId, remoteName])
  @@index([accountId])
  @@map("email_folders")
}

model EmailMessage {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  accountId         String    @map("account_id")
  folderId          String    @map("folder_id")
  remoteUid         Int       @map("remote_uid")
  messageId         String?   @map("message_id") @db.VarChar(512)
  threadId          String?   @map("thread_id") @db.VarChar(512)
  fromAddress       String    @map("from_address") @db.VarChar(512)
  fromName          String?   @map("from_name") @db.VarChar(256)
  toAddresses       String[]  @map("to_addresses")
  ccAddresses       String[]  @default([]) @map("cc_addresses")
  bccAddresses      String[]  @default([]) @map("bcc_addresses")
  subject           String    @db.VarChar(998)
  snippet           String?   @db.VarChar(256)
  bodyText          String?   @db.Text
  bodyHtmlSanitized String?   @map("body_html_sanitized") @db.Text
  receivedAt        DateTime  @map("received_at")
  sentAt            DateTime? @map("sent_at")
  isRead            Boolean   @default(false) @map("is_read")
  isFlagged         Boolean   @default(false) @map("is_flagged")
  isAnswered        Boolean   @default(false) @map("is_answered")
  hasAttachments    Boolean   @default(false) @map("has_attachments")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  account     EmailAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  folder      EmailFolder       @relation(fields: [folderId], references: [id])
  attachments EmailAttachment[]

  @@unique([accountId, folderId, remoteUid])
  @@index([tenantId])
  @@index([accountId])
  @@index([folderId])
  @@index([tenantId, isRead])
  @@index([tenantId, receivedAt(sort: Desc)])
  @@index([deletedAt])
  @@index([accountId, messageId])
  @@index([accountId, threadId])
  @@index([accountId, folderId, receivedAt(sort: Desc)])
  @@map("email_messages")
}

model EmailAttachment {
  id          String   @id @default(uuid())
  messageId   String   @map("message_id")
  filename    String   @db.VarChar(512)
  contentType String   @map("content_type") @db.VarChar(128)
  size        Int
  storageKey  String   @map("storage_key") @db.VarChar(1024)
  createdAt   DateTime @default(now()) @map("created_at")

  message EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("email_attachments")
}

// ===============================================
// TEAMS MODULE
// ===============================================

model Team {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  name              String    @db.VarChar(128)
  slug              String    @db.VarChar(128)
  description       String?   @db.Text
  avatarUrl         String?   @map("avatar_url") @db.VarChar(512)
  color             String?   @db.VarChar(7)
  isActive          Boolean   @default(true) @map("is_active")
  permissionGroupId String?   @map("permission_group_id")
  storageFolderId   String?   @map("storage_folder_id")
  settings          Json      @default("{}")
  createdBy         String    @map("created_by")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  creator             User                 @relation("TeamsCreated", fields: [createdBy], references: [id])
  members             TeamMember[]
  emailAccounts       TeamEmailAccount[]
  teamCalendarConfigs TeamCalendarConfig[]
  folderAccessRules   FolderAccessRule[]
  boards              Board[]
  analyticsGoals      AnalyticsGoal[]

  @@unique([tenantId, slug, deletedAt], name: "teams_slug_tenant_unique_active")
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([createdBy])
  @@index([deletedAt])
  @@map("teams")
}

model TeamMember {
  id        String         @id @default(uuid())
  tenantId  String         @map("tenant_id")
  teamId    String         @map("team_id")
  userId    String         @map("user_id")
  role      TeamMemberRole @default(MEMBER)
  joinedAt  DateTime       @default(now()) @map("joined_at")
  leftAt    DateTime?      @map("left_at")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([teamId, userId, leftAt], name: "team_members_unique_active")
  @@index([tenantId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

model TeamEmailAccount {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  teamId    String @map("team_id")
  accountId String @map("account_id")

  // Role-based permission defaults
  ownerCanRead    Boolean @default(true) @map("owner_can_read")
  ownerCanSend    Boolean @default(true) @map("owner_can_send")
  ownerCanManage  Boolean @default(true) @map("owner_can_manage")
  adminCanRead    Boolean @default(true) @map("admin_can_read")
  adminCanSend    Boolean @default(true) @map("admin_can_send")
  adminCanManage  Boolean @default(false) @map("admin_can_manage")
  memberCanRead   Boolean @default(true) @map("member_can_read")
  memberCanSend   Boolean @default(false) @map("member_can_send")
  memberCanManage Boolean @default(false) @map("member_can_manage")

  linkedBy  String   @map("linked_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  team    Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  account EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  linker  User         @relation("TeamEmailLinker", fields: [linkedBy], references: [id])

  @@unique([teamId, accountId])
  @@index([tenantId])
  @@index([teamId])
  @@index([accountId])
  @@map("team_email_accounts")
}

// ===============================================
// TASK BOARD MODULE
// ===============================================

// --- Enums ---

enum BoardType {
  PERSONAL
  TEAM
}

enum BoardVisibility {
  PRIVATE
  SHARED
}

enum BoardView {
  KANBAN
  TABLE
  CALENDAR
  TIMELINE
  DASHBOARD
}

enum BoardMemberRole {
  VIEWER
  EDITOR
}

enum CardIntegrationType {
  CUSTOMER
  PRODUCT
  FINANCE_ENTRY
  EMAIL
  DEPARTMENT
  CALENDAR_EVENT
}

enum CardStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum CardPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  CHECKBOX
  SELECT
  MULTI_SELECT
}

enum CardActivityType {
  CREATED
  UPDATED
  MOVED
  ASSIGNED
  COMMENTED
  COMMENT_ADDED
  FIELD_CHANGED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  LABEL_ADDED
  LABEL_REMOVED
  SUBTASK_ADDED
  SUBTASK_UPDATED
  SUBTASK_REMOVED
  SUBTASK_COMPLETED
  SUBTASK_REOPENED
  CHECKLIST_ITEM_COMPLETED
  CHECKLIST_ITEM_UNCOMPLETED
  AUTOMATION_TRIGGERED
  ARCHIVED
  RESTORED
  DELETED
}

enum AutomationTrigger {
  CARD_MOVED
  CARD_CREATED
  DUE_DATE_REACHED
  ALL_SUBTASKS_DONE
  FIELD_CHANGED
}

enum AutomationAction {
  SET_FIELD
  MOVE_CARD
  ASSIGN_USER
  ADD_LABEL
  SEND_NOTIFICATION
  COMPLETE_CARD
}

// --- Models ---

model Board {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  title           String          @db.VarChar(256)
  description     String?         @db.Text
  type            BoardType       @default(PERSONAL)
  teamId          String?         @map("team_id")
  ownerId         String          @map("owner_id")
  storageFolderId String?         @map("storage_folder_id")
  visibility      BoardVisibility @default(PRIVATE)
  defaultView     BoardView       @default(KANBAN) @map("default_view")
  settings        Json?
  metadata        Json?
  position        Int             @default(0)
  gradientId      String?         @map("gradient_id") @db.VarChar(32)

  archivedAt DateTime? @map("archived_at")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  owner         User               @relation("BoardOwner", fields: [ownerId], references: [id])
  team          Team?              @relation(fields: [teamId], references: [id])
  storageFolder StorageFolder?     @relation(fields: [storageFolderId], references: [id])
  columns       BoardColumn[]
  cards         Card[]
  labels        BoardLabel[]
  members       BoardMember[]
  customFields  BoardCustomField[]
  activities    CardActivity[]
  automations   BoardAutomation[]
  watchers      CardWatcher[]

  @@index([tenantId])
  @@index([tenantId, ownerId])
  @@index([tenantId, teamId])
  @@index([tenantId, deletedAt])
  @@map("boards")
}

model BoardColumn {
  id      String @id @default(uuid())
  boardId String @map("board_id")

  title     String  @db.VarChar(256)
  color     String? @db.VarChar(7)
  position  Int     @default(0)
  isDefault Boolean @default(false) @map("is_default")
  isDone    Boolean @default(false) @map("is_done")
  wipLimit  Int?    @map("wip_limit")

  archivedAt DateTime? @map("archived_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
  @@index([boardId, position])
  @@map("board_columns")
}

model Card {
  id           String  @id @default(uuid())
  boardId      String  @map("board_id")
  columnId     String  @map("column_id")
  parentCardId String? @map("parent_card_id")

  title       String       @db.VarChar(512)
  description String?      @db.Text
  status      CardStatus   @default(OPEN)
  priority    CardPriority @default(NONE)
  position    Int          @default(0)

  assigneeId String? @map("assignee_id")
  reporterId String  @map("reporter_id")

  startDate        DateTime? @map("start_date")
  dueDate          DateTime? @map("due_date")
  completedAt      DateTime? @map("completed_at")
  estimatedMinutes Int?      @map("estimated_minutes")

  coverColor   String? @map("cover_color") @db.VarChar(7)
  coverImageId String? @map("cover_image_id")
  metadata     Json?

  systemSourceType String? @map("system_source_type") @db.VarChar(64)
  systemSourceId   String? @map("system_source_id")

  archivedAt DateTime? @map("archived_at")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  board      Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column     BoardColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  parentCard Card?       @relation("CardSubtasks", fields: [parentCardId], references: [id])
  subtasks   Card[]      @relation("CardSubtasks")
  assignee   User?       @relation("CardAssignee", fields: [assigneeId], references: [id])
  reporter   User        @relation("CardReporter", fields: [reporterId], references: [id])

  labels            CardLabel[]
  customFieldValues CardCustomFieldValue[]
  comments          CardComment[]
  attachments       CardAttachment[]
  checklists        CardChecklist[]
  activities        CardActivity[]
  watchers          CardWatcher[]
  integrations      CardIntegration[]

  @@index([boardId])
  @@index([boardId, columnId])
  @@index([boardId, assigneeId])
  @@index([boardId, parentCardId])
  @@index([boardId, deletedAt])
  @@index([boardId, status])
  @@index([boardId, priority])
  @@index([dueDate])
  @@index([systemSourceType, systemSourceId])
  @@map("cards")
}

model BoardLabel {
  id      String @id @default(uuid())
  boardId String @map("board_id")

  name     String @db.VarChar(64)
  color    String @db.VarChar(7)
  position Int    @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  board Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]

  @@index([boardId])
  @@map("board_labels")
}

model CardLabel {
  cardId  String @map("card_id")
  labelId String @map("label_id")

  card  Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label BoardLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
  @@index([labelId])
  @@map("card_labels")
}

model BoardMember {
  id      String @id @default(uuid())
  boardId String @map("board_id")
  userId  String @map("user_id")

  role BoardMemberRole @default(VIEWER)

  createdAt DateTime @default(now()) @map("created_at")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@unique([boardId, userId])
  @@index([boardId])
  @@index([userId])
  @@map("board_members")
}

model BoardCustomField {
  id      String @id @default(uuid())
  boardId String @map("board_id")

  name       String          @db.VarChar(128)
  type       CustomFieldType
  options    Json?
  position   Int             @default(0)
  isRequired Boolean         @default(false) @map("is_required")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  board  Board                  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  values CardCustomFieldValue[]

  @@index([boardId])
  @@map("board_custom_fields")
}

model CardCustomFieldValue {
  id      String @id @default(uuid())
  cardId  String @map("card_id")
  fieldId String @map("field_id")

  value Json

  card  Card             @relation(fields: [cardId], references: [id], onDelete: Cascade)
  field BoardCustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([cardId, fieldId])
  @@map("card_custom_field_values")
}

model CardComment {
  id       String @id @default(uuid())
  cardId   String @map("card_id")
  authorId String @map("author_id")

  content  String @db.Text
  mentions Json?

  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")

  card      Card              @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author    User              @relation(fields: [authorId], references: [id])
  reactions CommentReaction[]

  @@index([cardId])
  @@index([cardId, deletedAt])
  @@index([authorId])
  @@map("card_comments")
}

model CommentReaction {
  id        String @id @default(uuid())
  commentId String @map("comment_id")
  userId    String @map("user_id")
  emoji     String @db.VarChar(16)

  createdAt DateTime @default(now()) @map("created_at")

  comment CardComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id])

  @@unique([commentId, userId, emoji])
  @@map("comment_reactions")
}

model CardAttachment {
  id     String @id @default(uuid())
  cardId String @map("card_id")
  fileId String @map("file_id")

  addedBy String @map("added_by")

  createdAt DateTime @default(now()) @map("created_at")

  card Card        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  file StorageFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@map("card_attachments")
}

model CardChecklist {
  id     String @id @default(uuid())
  cardId String @map("card_id")

  title    String @db.VarChar(256)
  position Int    @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  card  Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items ChecklistItem[]

  @@index([cardId])
  @@map("card_checklists")
}

model ChecklistItem {
  id          String @id @default(uuid())
  checklistId String @map("checklist_id")

  title       String    @db.VarChar(512)
  isCompleted Boolean   @default(false) @map("is_completed")
  assigneeId  String?   @map("assignee_id")
  dueDate     DateTime? @map("due_date")
  position    Int       @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  checklist CardChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  assignee  User?         @relation("ChecklistItemAssignee", fields: [assigneeId], references: [id])

  @@index([checklistId])
  @@map("checklist_items")
}

model CardActivity {
  id      String @id @default(uuid())
  cardId  String @map("card_id")
  boardId String @map("board_id")
  userId  String @map("user_id")

  type        CardActivityType
  description String           @db.Text
  field       String?          @db.VarChar(128)
  oldValue    Json?            @map("old_value")
  newValue    Json?            @map("new_value")
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  board Board @relation(fields: [boardId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([cardId])
  @@index([boardId])
  @@index([cardId, createdAt])
  @@map("card_activities")
}

model BoardAutomation {
  id      String @id @default(uuid())
  boardId String @map("board_id")

  name     String  @db.VarChar(256)
  isActive Boolean @default(true) @map("is_active")

  trigger       AutomationTrigger
  triggerConfig Json              @map("trigger_config")
  action        AutomationAction
  actionConfig  Json              @map("action_config")

  createdBy String @map("created_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([boardId, isActive])
  @@map("board_automations")
}

model CardWatcher {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  userId    String   @map("user_id")
  boardId   String   @map("board_id")
  role      String   @default("WATCHER") // "WATCHER" | "MEMBER"
