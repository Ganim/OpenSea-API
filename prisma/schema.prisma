  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  name     String                @db.VarChar(128)
  isActive Boolean               @default(true) @map("is_active")
  action   FinanceApprovalAction

  // Quick-access filter (also duplicated inside conditions JSON for the engine)
  maxAmount Decimal? @map("max_amount") @db.Decimal(12, 2)

  // Full conditions: { categoryIds?, supplierNames?, entryType?, minRecurrence? }
  conditions Json @default("{}")

  priority     Int @default(0) // Higher = evaluated first
  appliedCount Int @default(0) @map("applied_count")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("finance_approval_rules")
}

