// ===============================================
// COMPLIANCE — Rubrica mapping (Plan 06-05 Part B / A5 gap)
// ===============================================

// Mapeia conceitos CLT (HE_50, HE_100, DSR, FERIAS, etc.) → codRubr + ideTabRubr
// configurados pelo tenant na Tabela S-1010 do eSocial.
// Usado por `BuildS1200ForCompetenciaUseCase` para traduzir totais consolidados
// (TimeBank + Overtime + Payroll) em `S1200ItemRemun` aceitáveis pelo governo.
//
// Investigação A5 (2026-04-23) confirmou que o `EsocialRubrica` existente é um
// CRUD genérico sem campo `clrConcept` — este model é a ponte faltante.
model ComplianceRubricaMap {
  id         String  @id @default(uuid())
  tenantId   String  @map("tenant_id")
  clrConcept String  @map("clt_concept") @db.VarChar(32) // HE_50 | HE_100 | DSR | FERIAS | FALTA_JUSTIFICADA | SALARIO_BASE
  codRubr    String  @map("cod_rubr") @db.VarChar(16)
  ideTabRubr String  @map("ide_tab_rubr") @db.VarChar(16)
  indApurIR  Int?    @map("ind_apur_ir") @db.SmallInt

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String   @map("updated_by")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, clrConcept])
  @@index([tenantId])
  @@map("compliance_rubrica_map")
}

