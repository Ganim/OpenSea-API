  @@map("generated_contents")
}

model ProductMockup {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  variantId        String  @map("variant_id")
  name             String  @db.VarChar(128)
  clientLogoFileId String? @map("client_logo_file_id")
  clientBrandName  String? @map("client_brand_name") @db.VarChar(128)
  customization    Json
  mockupTemplateId String? @map("mockup_template_id")

  // Generated
