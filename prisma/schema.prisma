  @@unique([cnpjHash, tenantId, deletedAt], name: "suppliers_cnpj_unique_active")
  @@index([sequentialCode])
  @@index([isActive])
  @@index([rating])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@map("suppliers")
}

model Manufacturer {
