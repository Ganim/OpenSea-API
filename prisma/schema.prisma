  tenant   Tenant      @relation(fields: [tenantId], references: [id])
  mandate  CipaMandate @relation(fields: [mandateId], references: [id])
  employee Employee    @relation(fields: [employeeId], references: [id])

  @@unique([mandateId, employeeId])
  @@index([tenantId])
  @@index([mandateId])
  @@index([employeeId])
  @@map("cipa_members")
}

// ===============================================
