  @@index([binId])
  @@index([snapshotDate])
  @@index([variantId, snapshotDate])
  @@map("stock_snapshots")
}

// --- Sistema de Inventário (Contagem de Estoque) ---

enum InventorySessionStatus {
  OPEN
  PAUSED
  COMPLETED
  CANCELLED
}

enum InventorySessionMode {
  BIN
  ZONE
  PRODUCT
}

enum InventorySessionItemStatus {
  PENDING
  CONFIRMED
  MISSING
  WRONG_BIN
  EXTRA
}

enum DivergenceResolution {
  LOSS_REGISTERED
  TRANSFERRED
  ENTRY_CREATED
  PENDING_REVIEW
}

model InventorySession {
  id             String                 @id @default(uuid())
  tenantId       String                 @map("tenant_id")
  userId         String                 @map("user_id")
  status         InventorySessionStatus @default(OPEN)
  mode           InventorySessionMode
  binId          String?                @map("bin_id")
  zoneId         String?                @map("zone_id")
  productId      String?                @map("product_id")
  variantId      String?                @map("variant_id")
  totalItems     Int                    @default(0) @map("total_items")
  scannedItems   Int                    @default(0) @map("scanned_items")
  confirmedItems Int                    @default(0) @map("confirmed_items")
  divergentItems Int                    @default(0) @map("divergent_items")
  notes          String?                @db.Text
  startedAt      DateTime               @default(now()) @map("started_at")
  completedAt    DateTime?              @map("completed_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  user    User     @relation("InventorySessionUser", fields: [userId], references: [id])
  bin     Bin?     @relation(fields: [binId], references: [id])
  zone    Zone?    @relation(fields: [zoneId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
  variant Variant? @relation(fields: [variantId], references: [id])

  items InventorySessionItem[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, mode])
  @@index([userId])
  @@index([binId])
  @@index([zoneId])
  @@index([productId])
  @@index([variantId])
  @@map("inventory_sessions")
}

model InventorySessionItem {
  id            String                     @id @default(uuid())
  sessionId     String                     @map("session_id")
  itemId        String                     @map("item_id")
  expectedBinId String?                    @map("expected_bin_id")
  actualBinId   String?                    @map("actual_bin_id")
  status        InventorySessionItemStatus @default(PENDING)
  scannedAt     DateTime?                  @map("scanned_at")
  resolution    DivergenceResolution?
  resolvedBy    String?                    @map("resolved_by")
  resolvedAt    DateTime?                  @map("resolved_at")
  notes         String?                    @db.Text
  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @updatedAt @map("updated_at")

  session     InventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  item        Item             @relation(fields: [itemId], references: [id])
  expectedBin Bin?             @relation("ExpectedBin", fields: [expectedBinId], references: [id])
  actualBin   Bin?             @relation("ActualBin", fields: [actualBinId], references: [id])
  resolver    User?            @relation("InventoryItemResolver", fields: [resolvedBy], references: [id])

  @@index([sessionId])
  @@index([itemId])
  @@index([sessionId, itemId])
  @@index([sessionId, status])
  @@map("inventory_session_items")
}

// --- Sistema de Clientes e Vendas ---

model Customer {
  id       String       @id @default(uuid())
  name     String       @db.VarChar(128)
  type     CustomerType @default(INDIVIDUAL)
  document String?      @db.VarChar(256) // CPF ou CNPJ
  email    String?      @db.VarChar(512)
  phone    String?      @db.VarChar(256)
  address  String?      @db.VarChar(512)
  city     String?      @db.VarChar(128)
  state    String?      @db.VarChar(2) // UF
  zipCode  String?      @map("zip_code") @db.VarChar(10)

  // Blind index hashes
  documentHash String? @map("document_hash") @db.VarChar(64)
  emailHash    String? @map("email_hash") @db.VarChar(64)

  country   String?   @db.VarChar(64)
  notes     String?   @db.Text
  isActive  Boolean   @default(true) @map("is_active")
  isSystem  Boolean   @default(false) @map("is_system")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // CRM Fields
  tradeName           String?       @map("trade_name") @db.VarChar(128)
  stateRegistration   String?       @map("state_registration") @db.VarChar(32)
  website             String?       @db.VarChar(256)
  addressNumber       String?       @map("address_number") @db.VarChar(20)
  addressComplement   String?       @map("address_complement") @db.VarChar(128)
  addressNeighborhood String?       @map("address_neighborhood") @db.VarChar(128)
  tags                String[]      @default([])
  customFields        Json?         @map("custom_fields")
  source              ContactSource @default(MANUAL)
  assignedToUserId    String?       @map("assigned_to_user_id")

  tenantId String @map("tenant_id")
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  salesOrders SalesOrder[]
  crmContacts CrmContact[]
  crmDeals    CrmDeal[]

  // Pricing Relations
  customerPrices CustomerPrice[]
  coupons        Coupon[]
  couponUsages   CouponUsage[]

  // Catalogs & Content AI Relations
  catalogs Catalog[]

  // Orders Relations
  orders               Order[]
  storeCredits         StoreCredit[]
  customerCreditLimits CustomerCreditLimit[]

  // Analytics Relations
  portalAccesses CustomerPortalAccess[]

  // POS Relations
  posTransactions PosTransaction[]
  posVisitLogs    PosVisitLog[]

  // Licitacoes Relations
  bids         Bid[]
  bidContracts BidContract[]

  // Messaging Relations
  messagingContacts MessagingContact[]

  // Sales Evolution Relations
  quotes        Quote[]
  proposals     Proposal[]
  conversations Conversation[]
  leadScores    LeadScore[]

  assignedTo     User?           @relation("CustomerAssignedTo", fields: [assignedToUserId], references: [id])
  contacts       Contact[]
  deals          Deal[]
  activities     Activity[]
  timelineEvents TimelineEvent[]

  @@unique([documentHash, tenantId, deletedAt], name: "customers_document_unique_active")
  @@index([documentHash])
  @@index([emailHash])
  @@index([isActive])
  @@index([type])
  @@index([tenantId])
  @@index([tenantId, source])
  @@index([tenantId, assignedToUserId])
  @@map("customers")
}

model SalesOrder {
  id          String      @id @default(uuid())
  orderNumber String      @map("order_number") @db.VarChar(64)
  status      OrderStatus @default(PENDING)
  totalPrice  Decimal     @map("total_price") @db.Decimal(10, 2)
  discount    Decimal?    @default(0) @db.Decimal(10, 2)
  finalPrice  Decimal     @map("final_price") @db.Decimal(10, 2)
  notes       String?     @db.Text
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  customerId String  @map("customer_id")
  createdBy  String? @map("created_by")
  tenantId   String  @map("tenant_id")
  tenant     Tenant  @relation(fields: [tenantId], references: [id])

  customer      Customer         @relation(fields: [customerId], references: [id])
  creator       User?            @relation("CreatedSalesOrders", fields: [createdBy], references: [id])
  items         SalesOrderItem[]
  itemMovements ItemMovement[]

  @@unique([orderNumber, tenantId, deletedAt], name: "sales_orders_order_number_unique_active")
  @@index([customerId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdBy])
  @@index([createdAt])
  @@index([tenantId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  variantId  String   @map("variant_id")
  quantity   Decimal  @db.Decimal(10, 3)
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 2)
  discount   Decimal? @default(0) @db.Decimal(10, 2)
  totalPrice Decimal  @map("total_price") @db.Decimal(10, 2)
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  order   SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant    @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([variantId])
  @@map("sales_order_items")
}

// --- CRM: Contacts, Pipelines, Stages ---

model CrmContact {
  id                String                @id @default(uuid())
  tenantId          String                @map("tenant_id")
  customerId        String                @map("customer_id")
  firstName         String                @map("first_name") @db.VarChar(100)
  lastName          String?               @map("last_name") @db.VarChar(100)
  fullName          String                @map("full_name") @db.VarChar(201)
  email             String?               @db.VarChar(254)
  phone             String?               @db.VarChar(30)
  whatsapp          String?               @db.VarChar(30)
  role              ContactRole           @default(OTHER)
  jobTitle          String?               @map("job_title") @db.VarChar(150)
  department        String?               @db.VarChar(150)
  lifecycleStage    ContactLifecycleStage @default(LEAD) @map("lifecycle_stage")
  leadScore         Int                   @default(0) @map("lead_score")
  leadTemperature   String?               @map("lead_temperature") @db.VarChar(50)
  source            String                @default("MANUAL") @db.VarChar(100)
  lastInteractionAt DateTime?             @map("last_interaction_at")
  lastChannelUsed   String?               @map("last_channel_used") @db.VarChar(50)
  socialProfiles    Json?                 @map("social_profiles")
  tags              Json                  @default("[]")
  customFields      Json?                 @map("custom_fields")
  avatarUrl         String?               @map("avatar_url") @db.VarChar(500)
  assignedToUserId  String?               @map("assigned_to_user_id")
  isMainContact     Boolean               @default(false) @map("is_main_contact")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  deletedAt         DateTime?             @map("deleted_at")

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  customer      Customer      @relation(fields: [customerId], references: [id])
  assignedTo    User?         @relation("AssignedContacts", fields: [assignedToUserId], references: [id])
  crmDeals      CrmDeal[]
  crmActivities CrmActivity[]

  // Orders Relations
  orders Order[]

  // Digital Signature Relations
  signerAssignments SignatureEnvelopeSigner[] @relation("SignerContact")

  // Analytics Relations
  portalAccesses CustomerPortalAccess[]

  @@index([tenantId])
  @@index([customerId])
  @@index([assignedToUserId])
  @@index([lifecycleStage])
  @@index([tenantId, deletedAt])
  @@map("crm_contacts")
}

model CrmPipeline {
  id String @id @default(uuid())

  tenantId       String       @map("tenant_id")
  name           String       @db.VarChar(128)
  description    String?      @db.Text
  icon           String?      @db.VarChar(64)
  color          String?      @db.VarChar(16)
  type           PipelineType @default(SALES)
  isDefault      Boolean      @default(false) @map("is_default")
  isSystem       Boolean      @default(false) @map("is_system")
  position       Int          @default(0)
  nextPipelineId String?      @map("next_pipeline_id")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  tenant Tenant             @relation(fields: [tenantId], references: [id])
  stages CrmPipelineStage[]
  deals  CrmDeal[]

  // Orders Relations
  orders Order[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([isActive])
  @@map("crm_pipelines")
}

model CrmPipelineStage {
