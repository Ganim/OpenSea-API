  size         Int
  mimeType     String  @map("mime_type") @db.VarChar(128)
  fileType     String  @map("file_type") @db.VarChar(64)
  thumbnailKey String? @map("thumbnail_key") @db.VarChar(512)

  status         StorageFileStatus @default(ACTIVE)
  currentVersion Int               @default(1) @map("current_version")

  entityType String?   @map("entity_type") @db.VarChar(64)
  entityId   String?   @map("entity_id")
  expiresAt  DateTime? @map("expires_at")
  uploadedBy String    @map("uploaded_by")

  // Security
  isEncrypted    Boolean @default(false) @map("is_encrypted")
  isProtected    Boolean @default(false) @map("is_protected")
  protectionHash String? @map("protection_hash") @db.VarChar(256)
  isHidden       Boolean @default(false) @map("is_hidden")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant          Tenant               @relation(fields: [tenantId], references: [id])
  folder          StorageFolder?       @relation(fields: [folderId], references: [id])
  versions        StorageFileVersion[]
  shareLinks      StorageShareLink[]
  cardAttachments CardAttachment[]

  @@unique([tenantId, path, deletedAt], name: "storage_files_path_tenant_unique")
  @@index([tenantId])
  @@index([folderId])
  @@index([fileType])
  @@index([entityType, entityId])
  @@index([uploadedBy])
  @@index([tenantId, deletedAt])
  @@index([tenantId, folderId, deletedAt])
  @@map("storage_files")
}

model StorageFileVersion {
  id     String @id @default(uuid())
  fileId String @map("file_id")

  version    Int
  fileKey    String  @map("file_key") @db.VarChar(512)
  size       Int
  mimeType   String  @map("mime_type") @db.VarChar(128)
  changeNote String? @map("change_note") @db.VarChar(512)
  uploadedBy String  @map("uploaded_by")

  createdAt DateTime @default(now()) @map("created_at")

  file StorageFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, version])
  @@index([fileId])
  @@map("storage_file_versions")
}

model FolderAccessRule {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  folderId String  @map("folder_id")
  userId   String? @map("user_id")
  groupId  String? @map("group_id")
  teamId   String? @map("team_id")

  canRead     Boolean @default(true) @map("can_read")
  canWrite    Boolean @default(false) @map("can_write")
  canDelete   Boolean @default(false) @map("can_delete")
  canShare    Boolean @default(false) @map("can_share")
  isInherited Boolean @default(false) @map("is_inherited")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant           @relation(fields: [tenantId], references: [id])
  folder StorageFolder    @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user   User?            @relation(fields: [userId], references: [id])
  group  PermissionGroup? @relation(fields: [groupId], references: [id])
  team   Team?            @relation(fields: [teamId], references: [id])

  @@unique([folderId, userId], name: "folder_access_user_unique")
  @@unique([folderId, groupId], name: "folder_access_group_unique")
  @@unique([folderId, teamId], name: "folder_access_team_unique")
  @@index([tenantId])
  @@index([folderId])
  @@index([userId])
  @@index([groupId])
  @@index([teamId])
  @@index([folderId, userId])
  @@index([folderId, groupId])
  @@index([folderId, teamId])
  @@map("folder_access_rules")
}

model StorageShareLink {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  fileId   String @map("file_id")

  token         String    @unique @db.VarChar(128)
  expiresAt     DateTime? @map("expires_at")
  password      String?   @db.VarChar(512)
  maxDownloads  Int?      @map("max_downloads")
  downloadCount Int       @default(0) @map("download_count")
  isActive      Boolean   @default(true) @map("is_active")
  createdBy     String    @map("created_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant      @relation(fields: [tenantId], references: [id])
  file   StorageFile @relation(fields: [fileId], references: [id])

  @@index([tenantId])
  @@index([fileId])
  @@index([token])
  @@index([createdBy])
  @@map("storage_share_links")
}

