// ============================================================================
// HR — Phase 5-6: Performance Competencies, Kudos Social, Read Receipts,
//                 Salary History, 1:1 Meetings
// ============================================================================

// Competencies inside a performance review (1-5 score per competency).
// Defaults: Tecnica, Comunicacao, Lideranca, Ownership, Entrega.
model ReviewCompetency {
  id           String  @id @default(cuid())
  tenantId     String  @map("tenant_id")
  reviewId     String  @map("review_id")
  name         String  @db.VarChar(64)
  selfScore    Float?  @map("self_score") // 1.0 to 5.0
  managerScore Float?  @map("manager_score") // 1.0 to 5.0
  weight       Float   @default(1.0)
  comments     String? @db.Text

  review PerformanceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tenant Tenant            @relation(fields: [tenantId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([reviewId])
  @@map("hr_review_competencies")
}

// Emoji reactions on kudos posts.
model KudosReaction {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  kudosId    String @map("kudos_id")
  employeeId String @map("employee_id")
  emoji      String @db.VarChar(16)

  createdAt DateTime @default(now()) @map("created_at")

  kudos    EmployeeKudos @relation(fields: [kudosId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId], references: [id])
  tenant   Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([kudosId, employeeId, emoji])
  @@index([tenantId])
  @@index([kudosId])
  @@map("hr_kudos_reactions")
}

// Threaded replies on kudos posts.
model KudosReply {
  id         String @id @default(cuid())
  tenantId   String @map("tenant_id")
  kudosId    String @map("kudos_id")
  employeeId String @map("employee_id")
  content    String @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  kudos    EmployeeKudos @relation(fields: [kudosId], references: [id], onDelete: Cascade)
  employee Employee      @relation(fields: [employeeId], references: [id])
  tenant   Tenant        @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([kudosId])
  @@map("hr_kudos_replies")
}

// Read receipts on company announcements.
model AnnouncementReadReceipt {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  announcementId String   @map("announcement_id")
  employeeId     String   @map("employee_id")
  readAt         DateTime @default(now()) @map("read_at")

  announcement CompanyAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  employee     Employee            @relation(fields: [employeeId], references: [id])
  tenant       Tenant              @relation(fields: [tenantId], references: [id])

  @@unique([announcementId, employeeId])
  @@index([tenantId])
  @@index([announcementId])
  @@map("hr_announcement_read_receipts")
}

// Salary change reasons for SalaryHistory.
enum SalaryChangeReason {
  ADMISSION // first salary definition
  ADJUSTMENT // general adjustment / dissidio
  PROMOTION // promotion
  MERIT // individual merit
  ROLE_CHANGE // lateral role change
  CORRECTION // error correction
}

// Historical record of salary changes per employee.
model SalaryHistory {
  id             String             @id @default(cuid())
  tenantId       String             @map("tenant_id")
  employeeId     String             @map("employee_id")
  previousSalary Decimal?           @map("previous_salary") @db.Decimal(15, 2)
  newSalary      Decimal            @map("new_salary") @db.Decimal(15, 2)
  reason         SalaryChangeReason
  notes          String?            @db.Text
  effectiveDate  DateTime           @map("effective_date")
  changedBy      String             @map("changed_by") // userId

  employee Employee @relation(fields: [employeeId], references: [id])
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([employeeId])
  @@index([effectiveDate])
  @@map("hr_salary_history")
}

// 1:1 meeting status (Lattice / 15Five inspired).
enum OneOnOneStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// Recurring 1:1 meetings between manager and direct report.
model OneOnOneMeeting {
  id                  String         @id @default(cuid())
  tenantId            String         @map("tenant_id")
  managerId           String         @map("manager_id") // employeeId of manager
  reportId            String         @map("report_id") // employeeId of direct report
  scheduledAt         DateTime       @map("scheduled_at")
  durationMinutes     Int            @default(30) @map("duration_minutes")
  status              OneOnOneStatus @default(SCHEDULED)
  privateNotesManager String?        @map("private_notes_manager") @db.Text // manager-only
  privateNotesReport  String?        @map("private_notes_report") @db.Text // report-only
  sharedNotes         String?        @map("shared_notes") @db.Text // both can see
  cancelledReason     String?        @map("cancelled_reason") @db.VarChar(255)

  talkingPoints TalkingPoint[]
  actionItems   OneOnOneActionItem[]

  manager Employee @relation("ManagerOneOnOnes", fields: [managerId], references: [id])
  report  Employee @relation("ReportOneOnOnes", fields: [reportId], references: [id])
  tenant  Tenant   @relation(fields: [tenantId], references: [id])

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([tenantId])
  @@index([managerId])
  @@index([reportId])
  @@index([scheduledAt])
  @@map("hr_one_on_one_meetings")
}

// Talking points added by either participant before / during a 1:1.
model TalkingPoint {
  id                String  @id @default(cuid())
  meetingId         String  @map("meeting_id")
  addedByEmployeeId String  @map("added_by_employee_id")
  content           String  @db.Text
  isResolved        Boolean @default(false) @map("is_resolved")
  position          Int     @default(0)

  meeting OneOnOneMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  addedBy Employee        @relation(fields: [addedByEmployeeId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@index([meetingId])
  @@map("hr_one_on_one_talking_points")
}

// Action items assigned during a 1:1.
model OneOnOneActionItem {
  id          String    @id @default(cuid())
  meetingId   String    @map("meeting_id")
  ownerId     String    @map("owner_id") // employeeId responsible
  content     String    @db.Text
  isCompleted Boolean   @default(false) @map("is_completed")
  dueDate     DateTime? @map("due_date")
  completedAt DateTime? @map("completed_at")

  meeting OneOnOneMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  owner   Employee        @relation(fields: [ownerId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([meetingId])
  @@index([ownerId])
  @@map("hr_one_on_one_action_items")
}

