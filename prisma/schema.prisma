  AMERICANAS
  ALIEXPRESS
  CASAS_BAHIA
  SHEIN
  CUSTOM
}

enum MarketplaceConnectionStatus {
  ACTIVE
  PAUSED
  DISCONNECTED
  ERROR
}

enum MarketplaceFulfillmentType {
  SELF
  MARKETPLACE
  HYBRID
}

enum MarketplaceListingStatus {
  DRAFT
  PENDING
  ACTIVE
  PAUSED
  ERROR
  OUT_OF_STOCK
  BLOCKED
  DELETED
}

enum MarketplaceOrderStatus {
  RECEIVED
  ACKNOWLEDGED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  DISPUTE
}

enum MarketplacePaymentType {
  SALE
  REFUND
  COMMISSION
  SHIPPING_FEE
  AD_CHARGE
  FULFILLMENT_FEE
  ADJUSTMENT
  TRANSFER
}

enum MarketplacePaymentStatus {
  PENDING
  SETTLED
  DISPUTED
  CANCELLED
}

// ─── Marketplace Models ─────────────────────────────────────────────

model MarketplaceConnection {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  marketplace MarketplaceType
  name        String                      @db.VarChar(256)
  status      MarketplaceConnectionStatus @default(ACTIVE)

  // Seller credentials
  sellerId       String?   @map("seller_id") @db.VarChar(256)
  sellerName     String?   @map("seller_name") @db.VarChar(256)
  accessToken    String?   @map("access_token") @db.Text
  refreshToken   String?   @map("refresh_token") @db.Text
  tokenExpiresAt DateTime? @map("token_expires_at")
  apiKey         String?   @map("api_key") @db.VarChar(512)
  apiSecret      String?   @map("api_secret") @db.VarChar(512)

  // Sync configuration
  syncProducts    Boolean @default(true) @map("sync_products")
  syncPrices      Boolean @default(true) @map("sync_prices")
  syncStock       Boolean @default(true) @map("sync_stock")
  syncOrders      Boolean @default(true) @map("sync_orders")
  syncMessages    Boolean @default(false) @map("sync_messages")
  syncIntervalMin Int     @default(15) @map("sync_interval_min")

  // Last sync info
  lastSyncAt     DateTime? @map("last_sync_at")
  lastSyncStatus String?   @map("last_sync_status") @db.VarChar(64)
  lastSyncError  String?   @map("last_sync_error") @db.Text

  // Pricing configuration
  priceTableId      String?  @map("price_table_id")
  commissionPercent Decimal? @map("commission_percent") @db.Decimal(6, 2)
  autoCalcPrice     Boolean  @default(false) @map("auto_calc_price")
  priceMultiplier   Decimal  @default(1) @map("price_multiplier") @db.Decimal(8, 4)

  // Fulfillment
  fulfillmentType    MarketplaceFulfillmentType @default(SELF) @map("fulfillment_type")
  defaultWarehouseId String?                    @map("default_warehouse_id")

  // Webhook
  webhookUrl    String? @map("webhook_url") @db.VarChar(1024)
  webhookSecret String? @map("webhook_secret") @db.VarChar(512)

  // Extra settings (JSON)
  settings Json?

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listings MarketplaceListing[]
  orders   MarketplaceOrder[]
  payments MarketplacePayment[]

  @@index([tenantId])
  @@index([tenantId, marketplace])
  @@index([tenantId, deletedAt])
  @@index([marketplace, sellerId])
  @@map("marketplace_connections")
}

model MarketplaceListing {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  connectionId    String  @map("connection_id")
  variantId       String  @map("variant_id")
  parentListingId String? @map("parent_listing_id")

  // External references
  externalListingId String  @map("external_listing_id") @db.VarChar(256)
  externalProductId String? @map("external_product_id") @db.VarChar(256)
  externalUrl       String? @map("external_url") @db.VarChar(1024)

  // Status
  status          MarketplaceListingStatus @default(DRAFT)
  statusReason    String?                  @map("status_reason") @db.VarChar(512)
  lastStatusCheck DateTime?                @map("last_status_check")

  // Pricing
  publishedPrice   Decimal? @map("published_price") @db.Decimal(12, 2)
  compareAtPrice   Decimal? @map("compare_at_price") @db.Decimal(12, 2)
  commissionAmount Decimal? @map("commission_amount") @db.Decimal(12, 2)
  netPrice         Decimal? @map("net_price") @db.Decimal(12, 2)

  // Stock
  publishedStock   Int @default(0) @map("published_stock")
  fulfillmentStock Int @default(0) @map("fulfillment_stock")

  // Category mapping
  externalCategoryId   String? @map("external_category_id") @db.VarChar(128)
  externalCategoryPath String? @map("external_category_path") @db.VarChar(1024)

  // Performance metrics
  totalSold     Int      @default(0) @map("total_sold")
  totalRevenue  Decimal  @default(0) @map("total_revenue") @db.Decimal(14, 2)
  averageRating Decimal? @map("average_rating") @db.Decimal(3, 2)
  reviewCount   Int      @default(0) @map("review_count")
  buyBoxOwner   Boolean  @default(false) @map("buy_box_owner")
  healthScore   Int?     @map("health_score")

  // Ads
  hasActiveAd Boolean @default(false) @map("has_active_ad")
  adSpend     Decimal @default(0) @map("ad_spend") @db.Decimal(12, 2)

  // Sync
  lastSyncAt DateTime? @map("last_sync_at")

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection    MarketplaceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  variant       Variant               @relation(fields: [variantId], references: [id])
  parentListing MarketplaceListing?   @relation("ListingParent", fields: [parentListingId], references: [id])
  childListings MarketplaceListing[]  @relation("ListingParent")

  @@index([tenantId])
  @@index([connectionId])
  @@index([variantId])
  @@index([connectionId, externalListingId])
  @@index([tenantId, deletedAt])
  @@map("marketplace_listings")
}

model MarketplaceOrder {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  connectionId     String  @map("connection_id")
  externalOrderId  String  @map("external_order_id") @db.VarChar(256)
  externalOrderUrl String? @map("external_order_url") @db.VarChar(1024)

  // Status
  status            MarketplaceOrderStatus @default(RECEIVED)
  marketplaceStatus String?                @map("marketplace_status") @db.VarChar(128)

  // Buyer info
  buyerName     String  @map("buyer_name") @db.VarChar(256)
  buyerDocument String? @map("buyer_document") @db.VarChar(32)
  buyerEmail    String? @map("buyer_email") @db.VarChar(256)
  buyerPhone    String? @map("buyer_phone") @db.VarChar(32)
  customerId    String? @map("customer_id")

  // Financials
  subtotal       Decimal @db.Decimal(12, 2)
  shippingCost   Decimal @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  marketplaceFee Decimal @default(0) @map("marketplace_fee") @db.Decimal(12, 2)
  netAmount      Decimal @map("net_amount") @db.Decimal(12, 2)
  currency       String  @default("BRL") @db.VarChar(3)

  // Shipping
  shippingMethod    String?   @map("shipping_method") @db.VarChar(128)
  trackingCode      String?   @map("tracking_code") @db.VarChar(128)
  trackingUrl       String?   @map("tracking_url") @db.VarChar(1024)
  shippingLabel     String?   @map("shipping_label") @db.Text
  estimatedDelivery DateTime? @map("estimated_delivery")
  shippedAt         DateTime? @map("shipped_at")
  deliveredAt       DateTime? @map("delivered_at")
  deliveryAddress   Json      @default("{}") @map("delivery_address")

  // Internal order link
  orderId String? @map("order_id")

  // Notes
  notes String? @db.Text

  // Timestamps
  receivedAt     DateTime  @map("received_at")
  acknowledgedAt DateTime? @map("acknowledged_at")
  processedAt    DateTime? @map("processed_at")

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection MarketplaceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  payments   MarketplacePayment[]

  @@index([tenantId])
  @@index([connectionId])
  @@index([connectionId, externalOrderId])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
  @@index([receivedAt])
  @@map("marketplace_orders")
}

model MarketplacePayment {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  connectionId       String  @map("connection_id")
  externalPaymentId  String? @map("external_payment_id") @db.VarChar(256)
  marketplaceOrderId String? @map("marketplace_order_id")

  type        MarketplacePaymentType
  description String?                @db.VarChar(512)

  // Amounts
  grossAmount Decimal @map("gross_amount") @db.Decimal(12, 2)
  feeAmount   Decimal @default(0) @map("fee_amount") @db.Decimal(12, 2)
  netAmount   Decimal @map("net_amount") @db.Decimal(12, 2)
  currency    String  @default("BRL") @db.VarChar(3)

  // Payment details
  installmentNumber Int?                     @map("installment_number")
  settlementDate    DateTime?                @map("settlement_date")
  status            MarketplacePaymentStatus @default(PENDING)

  // Finance integration
  financeEntryId String? @map("finance_entry_id")

  // Extra data
  metadata Json?

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant           Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection       MarketplaceConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  marketplaceOrder MarketplaceOrder?     @relation(fields: [marketplaceOrderId], references: [id])

  @@index([tenantId])
  @@index([connectionId])
  @@index([marketplaceOrderId])
  @@index([connectionId, status])
  @@index([tenantId, status])
  @@map("marketplace_payments")
}

// ===============================================
// UNIFIED MESSAGING
// ===============================================

// --- Enums ---

enum MessagingChannel {
  WHATSAPP
  INSTAGRAM
  TELEGRAM
}

enum MessagingDirection {
  INBOUND
  OUTBOUND
}

enum MessagingMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessagingMessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LOCATION
  TEMPLATE
  INTERACTIVE
  STICKER
}

enum MessagingAccountStatus {
  ACTIVE
  DISCONNECTED
  ERROR
  SUSPENDED
}

enum MessagingTemplateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MessagingTemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

// --- Models ---

model MessagingAccount {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  channel MessagingChannel
  name    String                 @db.VarChar(128)
  status  MessagingAccountStatus @default(ACTIVE)

  // Channel-specific identifiers
  phoneNumber   String? @map("phone_number") @db.VarChar(20)
  wabaId        String? @map("waba_id") @db.VarChar(64)
  igAccountId   String? @map("ig_account_id") @db.VarChar(64)
  tgBotToken    String? @map("tg_bot_token") @db.Text
  tgBotUsername String? @map("tg_bot_username") @db.VarChar(64)

  // OAuth/API credentials (encrypted)
  accessToken    String?   @map("access_token") @db.Text
  refreshToken   String?   @map("refresh_token") @db.Text
  tokenExpiresAt DateTime? @map("token_expires_at")

  // Config
  webhookUrl    String? @map("webhook_url") @db.VarChar(512)
  webhookSecret String? @map("webhook_secret") @db.VarChar(256)
  settings      Json?

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contacts  MessagingContact[]
  messages  MessagingMessage[]
  templates MessagingTemplate[]

  @@unique([tenantId, channel, phoneNumber])
  @@index([tenantId])
  @@index([tenantId, channel])
  @@map("messaging_accounts")
}

model MessagingContact {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  accountId String @map("account_id")

  channel    MessagingChannel
  externalId String           @map("external_id") @db.VarChar(128)

  name      String? @db.VarChar(256)
  username  String? @db.VarChar(128)
  avatarUrl String? @map("avatar_url") @db.VarChar(512)

  // Link to ERP customer
  customerId String? @map("customer_id")

  // Conversation state
  lastMessageAt DateTime? @map("last_message_at")
  unreadCount   Int       @default(0) @map("unread_count")
  isBlocked     Boolean   @default(false) @map("is_blocked")

  metadata Json?

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account  MessagingAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  customer Customer?          @relation(fields: [customerId], references: [id])
  messages MessagingMessage[]

  @@unique([accountId, externalId])
  @@index([tenantId])
  @@index([tenantId, channel])
  @@index([tenantId, lastMessageAt])
  @@map("messaging_contacts")
}

model MessagingMessage {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  accountId String @map("account_id")
  contactId String @map("contact_id")

  channel   MessagingChannel
  direction MessagingDirection
  type      MessagingMessageType   @default(TEXT)
  status    MessagingMessageStatus @default(PENDING)

  // Content
  text      String? @db.Text
  mediaUrl  String? @map("media_url") @db.VarChar(1024)
  mediaType String? @map("media_type") @db.VarChar(64)
  fileName  String? @map("file_name") @db.VarChar(256)

  // Template (WhatsApp)
  templateName   String? @map("template_name") @db.VarChar(128)
  templateParams Json?   @map("template_params")

  // External reference
  externalId String? @map("external_id") @db.VarChar(128)

  // Reply
  replyToMessageId String? @map("reply_to_message_id")

  // Error
  errorCode    String? @map("error_code") @db.VarChar(32)
  errorMessage String? @map("error_message") @db.VarChar(512)

  metadata Json?

  // Timestamps
  sentAt      DateTime? @map("sent_at")
  deliveredAt DateTime? @map("delivered_at")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account MessagingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact MessagingContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([accountId, contactId])
  @@index([tenantId, channel, createdAt])
  @@index([contactId, createdAt])
  @@index([externalId])
  @@map("messaging_messages")
}

model MessagingTemplate {
  id        String @id @default(uuid())
  tenantId  String @map("tenant_id")
  accountId String @map("account_id")

  name     String                    @db.VarChar(128)
  language String                    @db.VarChar(10)
  category MessagingTemplateCategory
  status   MessagingTemplateStatus   @default(PENDING)

  // Template structure
  components Json

  // External
  externalId String? @map("external_id") @db.VarChar(128)

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account MessagingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, name, language])
  @@index([tenantId])
  @@map("messaging_templates")
}

// ===============================================
// FISCAL DOCUMENTS
// ===============================================

// --- Enums ---

enum FiscalDocumentType {
  NFE
  NFCE
  NFSE
}

enum FiscalDocumentStatus {
  DRAFT
  PENDING
  AUTHORIZED
  CANCELLED
  DENIED
  CORRECTED
  INUTILIZED
}

enum FiscalEmissionType {
  NORMAL
  CONTINGENCY_SVC_AN
  CONTINGENCY_SVC_RS
  CONTINGENCY_EPEC
  CONTINGENCY_OFFLINE
}

enum FiscalEventType {
  AUTHORIZATION
  CANCELLATION
  CORRECTION_LETTER
  INUTILIZATION
  MANIFESTATION
}

enum FiscalProviderType {
  NUVEM_FISCAL
  FOCUS_NFE
  WEBMANIABR
  NFEWIZARD
}

// --- Models ---

model FiscalConfig {
  id       String @id @default(uuid())
  tenantId String @unique @map("tenant_id")

  provider    FiscalProviderType @default(NUVEM_FISCAL)
  environment NfeEnvironment     @default(HOMOLOGATION)

  // API credentials (encrypted)
  apiKey    String? @map("api_key") @db.Text
  apiSecret String? @map("api_secret") @db.Text

  // NF-e defaults
  defaultSeries           Int     @default(1) @map("default_series")
  lastNfeNumber           Int     @default(0) @map("last_nfe_number")
  lastNfceNumber          Int     @default(0) @map("last_nfce_number")
  defaultCfop             String? @map("default_cfop") @db.VarChar(10)
  defaultNaturezaOperacao String? @map("default_natureza_operacao") @db.VarChar(128)

  // Tax regime
  taxRegime TaxRegimeEnum @default(SIMPLES)

  // NFC-e
  nfceEnabled  Boolean @default(false) @map("nfce_enabled")
  nfceCscId    String? @map("nfce_csc_id") @db.VarChar(10)
  nfceCscToken String? @map("nfce_csc_token") @db.VarChar(128)

  // Certificate
  certificateId String? @map("certificate_id")

  // Contingency
  contingencyMode   FiscalEmissionType @default(NORMAL) @map("contingency_mode")
  contingencyReason String?            @map("contingency_reason") @db.VarChar(256)

  settings Json?

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  certificate FiscalCertificate? @relation(fields: [certificateId], references: [id])
  documents   FiscalDocument[]

  @@index([tenantId])
  @@map("fiscal_configs")
}

model FiscalCertificate {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  // Certificate data (encrypted)
  pfxData     Bytes  @map("pfx_data")
  pfxPassword String @map("pfx_password") @db.Text

  // Certificate metadata
  serialNumber String   @map("serial_number") @db.VarChar(64)
  issuer       String   @db.VarChar(256)
  subject      String   @db.VarChar(256)
  validFrom    DateTime @map("valid_from")
  validUntil   DateTime @map("valid_until")

  status CertificateStatus @default(ACTIVE)

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalConfig FiscalConfig[]

  @@index([tenantId])
  @@index([tenantId, validUntil])
  @@map("fiscal_certificates")
}

model FiscalDocument {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  configId String @map("config_id")

  type      FiscalDocumentType
  series    Int
  number    Int
  accessKey String?            @unique @map("access_key") @db.VarChar(44)

  status       FiscalDocumentStatus @default(DRAFT)
  emissionType FiscalEmissionType   @default(NORMAL) @map("emission_type")

  // Recipient
  recipientCnpjCpf String? @map("recipient_cnpj_cpf") @db.VarChar(14)
  recipientName    String? @map("recipient_name") @db.VarChar(256)
  recipientIe      String? @map("recipient_ie") @db.VarChar(20)

  // Nature of operation
  naturezaOperacao String? @map("natureza_operacao") @db.VarChar(128)
  cfop             String? @db.VarChar(10)

  // Totals
  totalProducts Decimal @default(0) @map("total_products") @db.Decimal(12, 2)
  totalDiscount Decimal @default(0) @map("total_discount") @db.Decimal(12, 2)
  totalShipping Decimal @default(0) @map("total_shipping") @db.Decimal(12, 2)
  totalTax      Decimal @default(0) @map("total_tax") @db.Decimal(12, 2)
  totalValue    Decimal @default(0) @map("total_value") @db.Decimal(12, 2)

  // XML
  xmlSent         String? @map("xml_sent") @db.Text
  xmlAuthorized   String? @map("xml_authorized") @db.Text
  xmlCancellation String? @map("xml_cancellation") @db.Text

  // DANFE
  danfePdfUrl String? @map("danfe_pdf_url") @db.VarChar(512)

  // Protocol
  protocolNumber String?   @map("protocol_number") @db.VarChar(32)
  protocolDate   DateTime? @map("protocol_date")

  // External provider reference
  externalId String? @map("external_id") @db.VarChar(128)

  // Link to sales
  orderId String? @map("order_id")

  // Cancellation
  cancelledAt  DateTime? @map("cancelled_at")
  cancelReason String?   @map("cancel_reason") @db.VarChar(256)

  // Correction
  correctionText String? @map("correction_text") @db.Text

  // Additional info
  additionalInfo String? @map("additional_info") @db.Text

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  config FiscalConfig @relation(fields: [configId], references: [id])
  order  Order?       @relation(fields: [orderId], references: [id])

  items          FiscalDocumentItem[]
  events         FiscalDocumentEvent[]
  financeEntries FinanceEntry[]

  @@unique([configId, type, series, number])
  @@index([tenantId])
  @@index([tenantId, type, status])
  @@index([tenantId, createdAt])
  @@index([orderId])
  @@map("fiscal_documents")
}

model FiscalDocumentItem {
  id               String @id @default(uuid())
  fiscalDocumentId String @map("fiscal_document_id")

  itemNumber Int @map("item_number")

