// ===============================================
// DIGITAL SIGNATURE TOOL
// ===============================================

// --- Enums ---

enum CertificateType {
  A1
  A3
  CLOUD_NEOID
  CLOUD_BIRDID
  CLOUD_OTHER
}

enum CertificateStatus {
  ACTIVE
  EXPIRED
  REVOKED
  PENDING_ACTIVATION
}

enum SignatureLevel {
  SIMPLE
  ADVANCED
  QUALIFIED
}

enum EnvelopeStatus {
  DRAFT
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
  REJECTED
}

enum EnvelopeRoutingType {
  SEQUENTIAL
  PARALLEL
  HYBRID
}

enum SignerRole {
  SIGNER
  APPROVER
  WITNESS
  REVIEWER
}

enum SignerStatus {
  PENDING
  NOTIFIED
  VIEWED
  SIGNED
  REJECTED
  EXPIRED
}

enum SignatureAuditType {
  CREATED
  SENT
  VIEWED
  SIGNED
  REJECTED
  REMINDED
  EXPIRED
  CANCELLED
  DOWNLOADED
  DOCUMENT_VERIFIED
  CERTIFICATE_VALIDATED
  OTP_SENT
  OTP_VERIFIED
  LINK_ACCESSED
}

// --- Models ---

model DigitalCertificate {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  name   String            @db.VarChar(128)
  type   CertificateType
  status CertificateStatus @default(ACTIVE)

  // Certificate info (extracted from PFX or cloud API)
  subjectName  String?   @map("subject_name")
  subjectCnpj  String?   @map("subject_cnpj")
  subjectCpf   String?   @map("subject_cpf")
  issuerName   String?   @map("issuer_name")
  serialNumber String?   @map("serial_number")
  validFrom    DateTime? @map("valid_from")
  validUntil   DateTime? @map("valid_until")
  thumbprint   String?

  // Storage
  pfxFileId       String? @map("pfx_file_id")
  pfxPassword     String? @map("pfx_password") // encrypted
  cloudProviderId String? @map("cloud_provider_id")

  // Alert
  alertDaysBefore Int @default(30) @map("alert_days_before")

  // Usage
  isDefault      Boolean   @default(false) @map("is_default")
  allowedModules String[]  @default([]) @map("allowed_modules")
  lastUsedAt     DateTime? @map("last_used_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant  Tenant                    @relation(fields: [tenantId], references: [id])
  pfxFile StorageFile?              @relation("CertificatePfxFile", fields: [pfxFileId], references: [id])
  signers SignatureEnvelopeSigner[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, validUntil])
  @@map("digital_certificates")
}

model SignatureEnvelope {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  title             String          @db.VarChar(256)
  description       String?
  status            EnvelopeStatus  @default(DRAFT)
  signatureLevel    SignatureLevel  @map("signature_level")
  minSignatureLevel SignatureLevel? @map("min_signature_level")

  // Verification code (human-legible ID shown in sign emails)
  verificationCode String? @map("verification_code") @db.VarChar(16)

  // Document
  documentFileId String  @map("document_file_id")
  documentHash   String  @map("document_hash") @db.VarChar(64)
  signedFileId   String? @map("signed_file_id")
  documentType   String  @default("PDF") @map("document_type") @db.VarChar(16)

  // Source (which module requested)
  sourceModule     String @map("source_module") @db.VarChar(32)
  sourceEntityType String @map("source_entity_type") @db.VarChar(64)
  sourceEntityId   String @map("source_entity_id")

  // Workflow
  routingType    EnvelopeRoutingType @map("routing_type")
  expiresAt      DateTime?           @map("expires_at")
  reminderDays   Int                 @default(3) @map("reminder_days")
  autoExpireDays Int?                @map("auto_expire_days")

  // Completion
  completedAt  DateTime? @map("completed_at")
  cancelledAt  DateTime? @map("cancelled_at")
  cancelReason String?   @map("cancel_reason")

  // Metadata
  createdByUserId String   @map("created_by_user_id")
  tags            String[] @default([])
  metadata        Json?

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant                    @relation(fields: [tenantId], references: [id])
  documentFile StorageFile               @relation("EnvelopeDocumentFile", fields: [documentFileId], references: [id])
  signedFile   StorageFile?              @relation("EnvelopeSignedFile", fields: [signedFileId], references: [id])
  createdBy    User                      @relation("EnvelopeCreator", fields: [createdByUserId], references: [id])
  signers      SignatureEnvelopeSigner[]
  auditTrail   SignatureAuditEvent[]
  quote        Quote?
  proposal     Proposal?

  @@unique([tenantId, verificationCode], map: "signature_envelopes_tenant_verification_code_key")
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, sourceModule, sourceEntityId])
  @@index([tenantId, createdByUserId])
  @@map("signature_envelopes")
}

model SignatureEnvelopeSigner {
  id         String @id @default(uuid())
  tenantId   String @map("tenant_id")
  envelopeId String @map("envelope_id")

  order  Int          @default(1)
  group  Int          @default(1)
  role   SignerRole   @default(SIGNER)
  status SignerStatus @default(PENDING)

  // Signer identity (internal user OR external person)
  userId           String? @map("user_id")
  contactId        String? @map("contact_id")
  externalName     String? @map("external_name")
  externalEmail    String? @map("external_email")
  externalPhone    String? @map("external_phone")
  externalDocument String? @map("external_document")

  // Signing method
  signatureLevel SignatureLevel @map("signature_level")
  certificateId  String?        @map("certificate_id")

  // Signing token (for external signers)
  accessToken          String?   @map("access_token") @db.VarChar(128)
  accessTokenExpiresAt DateTime? @map("access_token_expires_at")

  // Signature data
  signedAt             DateTime? @map("signed_at")
  signatureImageFileId String?   @map("signature_image_file_id")
  signatureData        Json?     @map("signature_data")

  // Evidence (for ADVANCED/QUALIFIED)
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  geoLatitude  Decimal? @map("geo_latitude") @db.Decimal(8, 6)
  geoLongitude Decimal? @map("geo_longitude") @db.Decimal(8, 6)
  otpVerified  Boolean  @default(false) @map("otp_verified")

  // OTP (Lei 14.063 ADVANCED level — code sent by email before signing)
  otpCodeHash  String?   @map("otp_code_hash") @db.VarChar(128)
  otpExpiresAt DateTime? @map("otp_expires_at")
  otpAttempts  Int       @default(0) @map("otp_attempts")
  otpSentAt    DateTime? @map("otp_sent_at")

  // Rejection
  rejectedAt     DateTime? @map("rejected_at")
  rejectedReason String?   @map("rejected_reason")

  // Notifications
  lastNotifiedAt    DateTime? @map("last_notified_at")
  notificationCount Int       @default(0) @map("notification_count")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  envelope       SignatureEnvelope   @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  user           User?               @relation("SignerUser", fields: [userId], references: [id])
  contact        CrmContact?         @relation("SignerContact", fields: [contactId], references: [id])
  certificate    DigitalCertificate? @relation(fields: [certificateId], references: [id])
  signatureImage StorageFile?        @relation("SignerSignatureImage", fields: [signatureImageFileId], references: [id])

  @@index([envelopeId])
  @@index([tenantId])
  @@index([envelopeId, order, group])
  @@index([accessToken])
  @@index([userId])
  @@index([tenantId, status])
  @@map("signature_envelope_signers")
}

model SignatureAuditEvent {
  id         String @id @default(uuid())
  envelopeId String @map("envelope_id")
  tenantId   String @map("tenant_id")

  type         SignatureAuditType
  signerId     String?            @map("signer_id")
  description  String             @db.VarChar(512)
  ipAddress    String?            @map("ip_address")
  userAgent    String?            @map("user_agent")
  geoLatitude  Decimal?           @map("geo_latitude") @db.Decimal(8, 6)
  geoLongitude Decimal?           @map("geo_longitude") @db.Decimal(8, 6)
  metadata     Json?

  timestamp DateTime @default(now())

  // Relations
  envelope SignatureEnvelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)

  @@index([envelopeId])
  @@index([tenantId])
  @@index([envelopeId, timestamp])
  @@map("signature_audit_events")
}

model SignatureTemplate {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  name           String              @db.VarChar(128)
  description    String?
  signatureLevel SignatureLevel      @map("signature_level")
  routingType    EnvelopeRoutingType @map("routing_type")
  signerSlots    Json                @map("signer_slots")
  expirationDays Int?                @map("expiration_days")
  reminderDays   Int                 @default(3) @map("reminder_days")
  isActive       Boolean             @default(true) @map("is_active")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("signature_templates")
}

