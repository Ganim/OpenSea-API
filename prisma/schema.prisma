  parentOrderId     String?               @map("parent_order_id")
  status            ProductionOrderStatus @default(DRAFT)
  priority          Int                   @default(50)
  quantityPlanned   Decimal               @map("quantity_planned") @db.Decimal(10, 4)
  quantityStarted   Decimal               @default(0) @map("quantity_started") @db.Decimal(10, 4)
  quantityCompleted Decimal               @default(0) @map("quantity_completed") @db.Decimal(10, 4)
  quantityScrapped  Decimal               @default(0) @map("quantity_scrapped") @db.Decimal(10, 4)
  plannedStartDate  DateTime?             @map("planned_start_date")
