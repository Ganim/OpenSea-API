model Bid {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")

  // Edital info
  portalName     String  @map("portal_name") @db.VarChar(64)
  portalEditalId String? @map("portal_edital_id") @db.VarChar(128)
  editalNumber   String  @map("edital_number") @db.VarChar(128)

  // Classification
  modality        BidModality
  criterionType   BidCriterion        @map("criterion_type")
  legalFramework  BidLegalFramework   @map("legal_framework")
  executionRegime BidExecutionRegime? @map("execution_regime")

  // Object
  object        String  @db.Text
  objectSummary String? @map("object_summary") @db.VarChar(512)

  // Organ (buyer)
  organName  String  @map("organ_name") @db.VarChar(256)
  organCnpj  String? @map("organ_cnpj") @db.VarChar(18)
  organState String? @map("organ_state") @db.VarChar(2)
  organCity  String? @map("organ_city") @db.VarChar(128)

  // Values
  estimatedValue   Decimal? @map("estimated_value") @db.Decimal(14, 2)
  ourProposalValue Decimal? @map("our_proposal_value") @db.Decimal(14, 2)
  finalValue       Decimal? @map("final_value") @db.Decimal(14, 2)
  margin           Decimal? @db.Decimal(6, 2)

  // Dates
  publicationDate DateTime? @map("publication_date")
  openingDate     DateTime  @map("opening_date")
  closingDate     DateTime? @map("closing_date")
  disputeDate     DateTime? @map("dispute_date")

  // Status
  status          BidStatus @default(DISCOVERED)
  viabilityScore  Int?      @map("viability_score")
  viabilityReason String?   @map("viability_reason") @db.VarChar(512)

  // Relations FKs
  customerId       String? @map("customer_id")
  assignedToUserId String? @map("assigned_to_user_id")

  // Preferences
  exclusiveMeEpp Boolean  @default(false) @map("exclusive_me_epp")
  deliveryStates String[] @default([]) @map("delivery_states")
  tags           String[] @default([])
  notes          String?  @db.Text

  // Files
  editalUrl    String? @map("edital_url") @db.VarChar(1024)
  editalFileId String? @map("edital_file_id")
  etpFileId    String? @map("etp_file_id")
  trFileId     String? @map("tr_file_id")

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer   Customer?    @relation(fields: [customerId], references: [id])
  assignedTo User?        @relation("BidAssignee", fields: [assignedToUserId], references: [id])
  editalFile StorageFile? @relation("BidEditalFile", fields: [editalFileId], references: [id])
  etpFile    StorageFile? @relation("BidEtpFile", fields: [etpFileId], references: [id])
  trFile     StorageFile? @relation("BidTrFile", fields: [trFileId], references: [id])

  items         BidItem[]
  proposals     BidProposal[]
  documents     BidDocument[]
  contracts     BidContract[]
  monitorEvents BidMonitorEvent[]
  history       BidHistory[]

  @@unique([tenantId, portalName, portalEditalId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, openingDate])
  @@index([tenantId, deletedAt])
  @@map("bids")
}

model BidItem {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  bidId    String @map("bid_id")

  itemNumber     Int     @map("item_number")
  lotNumber      Int?    @map("lot_number")
  lotDescription String? @map("lot_description") @db.VarChar(512)
  description    String  @db.Text

  quantity           Decimal  @db.Decimal(12, 4)
  unit               String   @db.VarChar(16)
  estimatedUnitPrice Decimal? @map("estimated_unit_price") @db.Decimal(14, 4)
  ourUnitPrice       Decimal? @map("our_unit_price") @db.Decimal(14, 4)
  finalUnitPrice     Decimal? @map("final_unit_price") @db.Decimal(14, 4)

  status          BidItemStatus @default(PENDING_BID_ITEM)
  variantId       String?       @map("variant_id")
  matchConfidence Decimal?      @map("match_confidence") @db.Decimal(5, 2)
  quotaType       BidQuotaType? @map("quota_type")
  notes           String?       @db.Text

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  bid    Bid    @relation(fields: [bidId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@index([tenantId])
  @@map("bid_items")
}

model BidProposal {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  bidId    String @map("bid_id")

  version    Int               @default(1)
  status     BidProposalStatus @default(DRAFT_PROPOSAL)
  totalValue Decimal           @map("total_value") @db.Decimal(14, 2)
  validUntil DateTime?         @map("valid_until")

  proposalFileId     String?   @map("proposal_file_id")
  sentAt             DateTime? @map("sent_at")
  sentByUserId       String?   @map("sent_by_user_id")
  sentByAi           Boolean   @default(false) @map("sent_by_ai")
  portalConfirmation String?   @map("portal_confirmation") @db.VarChar(256)
  notes              String?   @db.Text

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  bid          Bid          @relation(fields: [bidId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  proposalFile StorageFile? @relation("BidProposalFile", fields: [proposalFileId], references: [id])
  sentByUser   User?        @relation("BidProposalSender", fields: [sentByUserId], references: [id])

  @@index([bidId])
  @@index([tenantId])
  @@map("bid_proposals")
}

model BidDocument {
  id       String  @id @default(uuid())
  tenantId String  @map("tenant_id")
  bidId    String? @map("bid_id")

  type        BidDocumentType
  name        String          @db.VarChar(256)
  description String?         @db.VarChar(512)
  fileId      String          @map("file_id")

  issueDate      DateTime? @map("issue_date")
  expirationDate DateTime? @map("expiration_date")
  isValid        Boolean   @default(true) @map("is_valid")

  autoRenewable    Boolean              @default(false) @map("auto_renewable")
  lastRenewAttempt DateTime?            @map("last_renew_attempt")
  renewStatus      BidDocRenewalStatus? @map("renew_status")

  portalUploaded   Boolean   @default(false) @map("portal_uploaded")
  portalUploadedAt DateTime? @map("portal_uploaded_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bid    Bid?        @relation(fields: [bidId], references: [id], onDelete: Cascade)
  file   StorageFile @relation("BidDocumentFile", fields: [fileId], references: [id])

  @@index([tenantId])
  @@index([bidId])
  @@index([tenantId, type])
  @@index([expirationDate])
  @@map("bid_documents")
}

model BidContract {
  id       String @id @default(uuid())
  tenantId String @map("tenant_id")
  bidId    String @map("bid_id")

  contractNumber String            @map("contract_number") @db.VarChar(128)
  status         BidContractStatus @default(DRAFT_CONTRACT)

  signedDate DateTime? @map("signed_date")
  startDate  DateTime  @map("start_date")
  endDate    DateTime  @map("end_date")

  totalValue     Decimal @map("total_value") @db.Decimal(14, 2)
  remainingValue Decimal @map("remaining_value") @db.Decimal(14, 2)

  customerId        String    @map("customer_id")
  renewalCount      Int       @default(0) @map("renewal_count")
  maxRenewals       Int?      @map("max_renewals")
  renewalDeadline   DateTime? @map("renewal_deadline")
  deliveryAddresses Json?     @map("delivery_addresses")
  contractFileId    String?   @map("contract_file_id")
  notes             String?   @db.Text

  // Soft Delete
  deletedAt DateTime? @map("deleted_at")

  // Audit
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bid          Bid          @relation(fields: [bidId], references: [id], onDelete: Cascade)
  customer     Customer     @relation(fields: [customerId], references: [id])
  contractFile StorageFile? @relation("BidContractFile", fields: [contractFileId], references: [id])

  empenhos BidEmpenho[]

  @@unique([tenantId, contractNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([bidId])
  @@map("bid_contracts")
}

model BidEmpenho {
  id         String @id @default(uuid())
  tenantId   String @map("tenant_id")
  contractId String @map("contract_id")

  empenhoNumber String           @map("empenho_number") @db.VarChar(128)
  type          BidEmpenhoType
  value         Decimal          @db.Decimal(14, 2)
  issueDate     DateTime         @map("issue_date")
  status        BidEmpenhoStatus @default(EMITIDO)

  orderId String? @map("order_id")
